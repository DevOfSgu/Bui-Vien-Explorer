<?xml version="1.0" encoding="utf-8" ?>
<resources>
	<style name="Maui.MainTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
		<item name="android:windowNoTitle">true</item>
		<item name="android:windowActionBar">false</item>
		<item name="colorPrimary">@color/colorPrimary</item>
		<item name="colorPrimaryDark">@color/colorPrimaryDark</item>
		<item name="colorAccent">@color/colorAccent</item>
		<item name="android:statusBarColor">@color/colorPrimaryDark</item>
		<item name="android:navigationBarColor">@color/colorPrimaryDark</item>
		<!-- Ensure Material BottomNavigationView has valid TextAppearance from theme -->
		<item name="bottomNavigationStyle">@style/Widget.MaterialComponents.BottomNavigationView</item>
		<item name="textAppearanceCaption">@style/TextAppearance.MaterialComponents.Caption</item>
		<item name="textAppearanceSubtitle2">@style/TextAppearance.MaterialComponents.Subtitle2</item>
	</style>

	<style name="Maui.SplashTheme" parent="Maui.MainTheme">
		<item name="maui_splash">true</item>
	</style>
</resources>
