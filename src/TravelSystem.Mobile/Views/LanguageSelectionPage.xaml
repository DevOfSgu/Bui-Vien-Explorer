<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelSystem.Mobile.Views.LanguageSelectionPage"
             BackgroundColor="#FAF8F5"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*, Auto" Padding="24, 0, 24, 40">

        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never" Margin="0, 60, 0, 0">
            <VerticalStackLayout Spacing="32" Padding="0,0,0,80">

                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Border HeightRequest="80" WidthRequest="80" Background="White" Padding="0" HorizontalOptions="Center" Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#E5E5EA" Offset="0,5" Radius="10" Opacity="0.3" />
                        </Border.Shadow>
                        <Image Source="logoapp.png" Aspect="AspectFit" WidthRequest="100" HeightRequest="180" HorizontalOptions="Center" Margin="16" />
                    </Border>

                    <VerticalStackLayout Spacing="-8" HorizontalOptions="Center">
                        <Label Text="Bùi Viện" FontSize="36" FontFamily="SpaceGroteskBold" FontAttributes="Bold" TextColor="#1C1C1E" HorizontalOptions="Center" />
                        <Label Text="Explorer" FontSize="36" FontFamily="SpaceGroteskBold" FontAttributes="Bold" TextColor="#1C1C1E" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Label Text="AUDIO GUIDE EXPERIENCE" FontSize="11" FontAttributes="Bold" TextColor="#8E8E93" CharacterSpacing="1.5" HorizontalOptions="Center" Margin="0, 8, 0, 0" />
                </VerticalStackLayout>

                <Label Text="Choose Your Language" FontSize="18" FontFamily="SpaceGroteskBold" FontAttributes="Bold" TextColor="#1C1C1E" HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="16" x:Name="LanguageList">

                    <Border Stroke="#FF4B4B" StrokeThickness="1" Padding="20,16" Background="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#FFE5E5" Offset="0,10" Radius="20" Opacity="0.8" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageSelected" CommandParameter="vi" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="60, *, 40">
                            <Image Source="ic_flag_vn.png" WidthRequest="44" HeightRequest="44" Aspect="AspectFit" Grid.Column="0" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Tiếng Việt" FontSize="18" FontAttributes="Bold" TextColor="#FF4B4B" />
                                <Label Text="VIETNAMESE" FontSize="11" TextColor="#8E8E93" FontAttributes="Bold" CharacterSpacing="1" Margin="0,2,0,0"/>
                            </VerticalStackLayout>
                            <Border x:Name="vn_border" Grid.Column="2" WidthRequest="24" HeightRequest="24" Stroke="#FF4B4B" StrokeThickness="2" Background="White" Padding="4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Ellipse x:Name="viet_dot" Fill="#FF4B4B" IsVisible="True" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Stroke="Transparent" StrokeThickness="0" Padding="20,16" Background="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#E5E5EA" Offset="0,10" Radius="20" Opacity="0.4" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageSelected" CommandParameter="en" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="60, *, 40">
                            <Image Source="ic_flag_en.png" WidthRequest="44" HeightRequest="44" Aspect="AspectFit" Grid.Column="0" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="English" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" />
                                <Label Text="ENGLISH" FontSize="11" TextColor="#8E8E93" FontAttributes="Bold" CharacterSpacing="1" Margin="0,2,0,0"/>
                            </VerticalStackLayout>
                            <Border x:Name="eng_border" Grid.Column="2" WidthRequest="24" HeightRequest="24" Stroke="#E5E5EA" StrokeThickness="2" Background="Transparent">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Ellipse x:Name="end_dot"  Fill="#FF4B4B" IsVisible="False" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Stroke="Transparent" StrokeThickness="0" Padding="20,16" Background="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#E5E5EA" Offset="0,10" Radius="20" Opacity="0.4" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageSelected" CommandParameter="ja" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="60, *, 40">
                            <Image Source="japan.png" WidthRequest="44" HeightRequest="44" Aspect="AspectFit" Grid.Column="0" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="日本語" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" />
                                <Label Text="JAPANESE" FontSize="11" TextColor="#8E8E93" FontAttributes="Bold" CharacterSpacing="1" Margin="0,2,0,0"/>
                            </VerticalStackLayout>
                            <Border x:Name="jp_border" Grid.Column="2" WidthRequest="24" HeightRequest="24" Stroke="#E5E5EA" StrokeThickness="2" Background="Transparent">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Ellipse x:Name="jp_dot" IsVisible="False" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center" Fill="#FF4B4B" />
                            </Border>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="0" HeightRequest="100" VerticalOptions="End" InputTransparent="True">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00FAF8F5" Offset="0.0" />
                    <GradientStop Color="#FAF8F5" Offset="0.9" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <VerticalStackLayout Grid.Row="1" Spacing="20" Margin="0, 20, 0, 0">
            <Button Text="GET STARTED   ➔" FontAttributes="Bold" FontSize="16" TextColor="White" 
                    BackgroundColor="#FF4B4B" CornerRadius="28" HeightRequest="60" 
                    Command="{Binding GetStartedCommand}">
                <Button.Shadow>
                    <Shadow Brush="#FF4B4B" Offset="0,15" Radius="25" Opacity="0.4" />
                </Button.Shadow>
            </Button>

            <Label Text="Developed by Hao and Phong" 
                   FontSize="9" TextColor="#AEAEB2" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" CharacterSpacing="0.8" LineHeight="1.5" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>