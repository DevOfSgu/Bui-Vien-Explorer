<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:TravelSystem.Mobile.Views"
             xmlns:maps="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:services="clr-namespace:TravelSystem.Mobile.Services"
             x:Class="TravelSystem.Mobile.Views.TourDetailPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark={StaticResource OffBlack}}"
             Title="{Binding TourName}"
             Shell.TabBarIsVisible="False">

    <!-- AbsoluteLayout để bottom sheet chạy đè lên bản đồ -->
    <AbsoluteLayout x:Name="RootLayout">

        <!-- Bản đồ chiếm toàn màn hình -->
        <maps:MapControl x:Name="MapControlView"
                         AbsoluteLayout.LayoutFlags="All"
                         AbsoluteLayout.LayoutBounds="0,0,1,1" />

        <!-- Nút Focus (overlay góc phải trên) -->
        <Grid AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1"
              InputTransparent="True"
              CascadeInputTransparent="False">
            <ImageButton Source="location.svg"
                         Clicked="OnFocusBuiVienClicked"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         Margin="0,12,12,0"
                         WidthRequest="44"
                         HeightRequest="44"
                         Padding="11"
                         BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark={StaticResource DarkSurface}}"
                         BorderWidth="0"
                         CornerRadius="22"
                         Shadow="{x:Null}"
                         InputTransparent="False" />
        </Grid>

        <!-- Bottom Sheet Panel -->
        <Border x:Name="BottomSheet"
                BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkSurface}}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0"
                AbsoluteLayout.LayoutFlags="WidthProportional"
                AbsoluteLayout.LayoutBounds="0,9999,1,2000">

            <!-- Shadow -->
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-4" Radius="16" Opacity="0.12" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="0,0,0,8">

                <!-- Drag Handle -->
                <Grid Grid.Row="0"
                      HeightRequest="32"
                      HorizontalOptions="Fill"
                      VerticalOptions="Start"
                      BackgroundColor="Transparent">
                    <BoxView HeightRequest="5"
                             WidthRequest="44"
                             CornerRadius="3"
                             BackgroundColor="{AppThemeBinding Light=#9CA3AF, Dark={StaticResource Gray600}}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnBottomSheetPanUpdated" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Header: tiêu đề + số lượng -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto"
                      Padding="18,0,18,10">
                    <Label Grid.Column="0"
                           Text="{Binding TourStopsTitle}"
                           FontFamily="SpaceGroteskBold"
                           FontAttributes="Bold"
                           FontSize="22"
                           TextColor="{AppThemeBinding Light=#1F2937, Dark=White}"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding StopsCountText}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark={StaticResource Gray500}}"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnBottomSheetPanUpdated" />
                    </Grid.GestureRecognizers>
                </Grid>

                <Grid Grid.Row="2" Padding="18,0,18,10">
                    <Button Text="{Binding PoiSimulationButtonText}"
                            Command="{Binding TogglePoiSimulationCommand}"
                            HeightRequest="40"
                            FontSize="13"
                            CornerRadius="20"
                            BackgroundColor="{AppThemeBinding Light=#E5F5EC, Dark={StaticResource DarkAccentMuted}}"
                            TextColor="{AppThemeBinding Light=#0F5132, Dark=White}" />
                </Grid>

                <!-- Danh sách Zones -->
                <CollectionView x:Name="StopsCollectionView" Grid.Row="3"
                                ItemsSource="{Binding PoiStops}"
                                SelectionMode="None"
                                Margin="18,0,18,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Stroke="{AppThemeBinding Light=#EBEEF3, Dark={StaticResource Gray900}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark={StaticResource OffBlack}}">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E9F8EE, Dark={StaticResource DarkAccentMuted}}" />
                                        <Setter Property="Stroke" Value="{AppThemeBinding Light=#43A047, Dark={StaticResource DarkAccent}}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Grid WidthRequest="50" HeightRequest="50">
                                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark={StaticResource Gray900}}" StrokeShape="RoundRectangle 25">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        </Border>
                                    </Grid>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DistanceText}" FontSize="12" TextColor="{AppThemeBinding Light=#98A2B3, Dark={StaticResource Gray500}}" />
                                    </VerticalStackLayout>

                                    <Image Grid.Column="2" Source="arrow_forward_icon.svg"
                                           WidthRequest="18" HeightRequest="18"
                                           VerticalOptions="Center" Opacity="0.5" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToZoneDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <Border x:Name="RemoteHintToast"
                IsVisible="False"
                Opacity="0"
                TranslationY="-18"
                Margin="12,0,12,0"
                Padding="12,10"
                AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional"
                AbsoluteLayout.LayoutBounds="0.5,0.08,0.92,-1"
                BackgroundColor="{AppThemeBinding Light=#FFF7E6, Dark=#2D2417}"
                Stroke="{AppThemeBinding Light=#F5C26B, Dark=#7A5B2B}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 12">
            <Label Text="{Binding RemoteExploreHintText}"
                   FontSize="13"
                   LineBreakMode="WordWrap"
                   TextColor="{AppThemeBinding Light=#7A4F01, Dark=#F7D9A0}" />
        </Border>

        <!-- Loading overlay -->
        <Grid BackgroundColor="#66000000"
              IsVisible="{Binding IsLoading}"
              AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1">
            <VerticalStackLayout Spacing="10"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   Color="White"
                                   WidthRequest="40"
                                   HeightRequest="40" />
                <Label Text="{Binding [tour_loading], Source={x:Static services:LocalizationManager.Instance}}"
                       TextColor="White"
                       FontSize="14"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Audio Player Popup -->
        <views:AudioPlayerPopup x:Name="AudioPlayer" 
                               AbsoluteLayout.LayoutFlags="All"
                               AbsoluteLayout.LayoutBounds="0,0,1,1"/>

        <!-- Closed-hours popup -->
        <Grid x:Name="ClosedHoursOverlay"
              IsVisible="False"
              BackgroundColor="#77000000"
              AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1">
            <Border Margin="22"
                    Padding="18,16"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumWidthRequest="420"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFFDF8, Dark=#2A2218}"
                    StrokeShape="RoundRectangle 18">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="⚠"
                               FontSize="18"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#B45309, Dark=#FBBF24}" />
                        <Label Grid.Column="1"
                               Text="{Binding [closed_hours_title], Source={x:Static services:LocalizationManager.Instance}}"
                               FontFamily="SpaceGroteskBold"
                               FontAttributes="Bold"
                               FontSize="24"
                               LineBreakMode="WordWrap"
                               MaxLines="2"
                               TextColor="{AppThemeBinding Light=#B91C1C, Dark=#FCA5A5}" />
                    </Grid>

                    <Label x:Name="ClosedHoursMessageLabel"
                           LineBreakMode="WordWrap"
                           FontSize="17"
                           TextColor="{AppThemeBinding Light=#1F2937, Dark=#F3F4F6}" />

                    <Border Padding="10,6"
                            BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#123321}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0">
                        <Label x:Name="ClosedHoursRangeLabel"
                               FontAttributes="Bold"
                               FontFamily="SpaceGroteskBold"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#166534, Dark=#86EFAC}" />
                    </Border>

                        <Button Text="{Binding [closed_hours_ok], Source={x:Static services:LocalizationManager.Instance}}"
                            Clicked="OnClosedHoursPopupOkClicked"
                            HeightRequest="42"
                            CornerRadius="12"
                            HorizontalOptions="End"
                            BackgroundColor="{AppThemeBinding Light=#EF4444, Dark=#DC2626}"
                            TextColor="White"
                            FontAttributes="Bold"
                            WidthRequest="92" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </AbsoluteLayout>


</ContentPage>
