<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:TravelSystem.Mobile.Views"
             x:Class="TravelSystem.Mobile.Views.TourDetailPage"
             BackgroundColor="#F3F4F6"
             Title="{Binding TourName}"
             Shell.TabBarIsVisible="False">

    <!-- AbsoluteLayout để bottom sheet chạy đè lên bản đồ -->
    <AbsoluteLayout x:Name="RootLayout">

        <!-- Bản đồ chiếm toàn màn hình -->
        <ContentView x:Name="MapHost"
                     AbsoluteLayout.LayoutFlags="All"
                     AbsoluteLayout.LayoutBounds="0,0,1,1" />

        <!-- Nút Focus (overlay góc phải trên) -->
        <Grid AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1"
              InputTransparent="True"
              CascadeInputTransparent="False">
            <ImageButton Source="location.svg"
                         Clicked="OnFocusBuiVienClicked"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         Margin="0,12,12,0"
                         WidthRequest="44"
                         HeightRequest="44"
                         Padding="11"
                         BackgroundColor="#FFFFFF"
                         BorderWidth="0"
                         CornerRadius="22"
                         Shadow="{x:Null}"
                         InputTransparent="False" />
        </Grid>

        <!-- Bottom Sheet Panel -->
        <Border x:Name="BottomSheet"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0"
                AbsoluteLayout.LayoutFlags="WidthProportional"
                AbsoluteLayout.LayoutBounds="0,9999,1,2000">

            <!-- Shadow -->
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-4" Radius="16" Opacity="0.12" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,*" Padding="0,0,0,8">

                <!-- Drag Handle -->
                <Grid Grid.Row="0"
                      HeightRequest="32"
                      HorizontalOptions="Fill"
                      VerticalOptions="Start"
                      BackgroundColor="Transparent">
                    <BoxView HeightRequest="5"
                             WidthRequest="44"
                             CornerRadius="3"
                             BackgroundColor="#9CA3AF"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnBottomSheetPanUpdated" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Header: tiêu đề + số lượng -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto"
                      Padding="18,0,18,10">
                    <Label Grid.Column="0"
                           Text="Tour Stops"
                           FontFamily="SpaceGroteskBold"
                           FontAttributes="Bold"
                           FontSize="22"
                           TextColor="#1F2937"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding PoiStops.Count, StringFormat='{0} điểm'}"
                           FontSize="13"
                           TextColor="#6B7280"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnBottomSheetPanUpdated" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Danh sách Zones -->
                <CollectionView x:Name="StopsCollectionView" Grid.Row="2"
                                ItemsSource="{Binding PoiStops}"
                                SelectionMode="None"
                                Margin="18,0,18,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Stroke="#EBEEF3"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="#FFFFFF">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#E9F8EE" />
                                        <Setter Property="Stroke" Value="#43A047" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Grid WidthRequest="50" HeightRequest="50">
                                        <Border StrokeThickness="0" BackgroundColor="#F3F4F6" StrokeShape="RoundRectangle 25">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        </Border>
                                    </Grid>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#1F2937" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DistanceText}" FontSize="12" TextColor="#98A2B3" />
                                    </VerticalStackLayout>

                                    <Image Grid.Column="2" Source="arrow_forward_icon.png"
                                           WidthRequest="18" HeightRequest="18"
                                           VerticalOptions="Center" Opacity="0.5" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToZoneDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Grid BackgroundColor="#66000000"
              IsVisible="{Binding IsLoading}"
              AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1">
            <VerticalStackLayout Spacing="10"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   Color="White"
                                   WidthRequest="40"
                                   HeightRequest="40" />
                <Label Text="Đang tải chi tiết tour..."
                       TextColor="White"
                       FontSize="14"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Audio Player Popup -->
        <views:AudioPlayerPopup x:Name="AudioPlayer" 
                               AbsoluteLayout.LayoutFlags="All"
                               AbsoluteLayout.LayoutBounds="0,0,1,1"/>
    </AbsoluteLayout>


</ContentPage>
