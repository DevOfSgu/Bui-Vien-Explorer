<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TravelSystem.Mobile.ViewModels"
             x:Class="TravelSystem.Mobile.Views.MainPage"
             BackgroundColor="#F3F4F6"
             x:DataType="vm:MainPageViewModel">

    <RefreshView Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Padding="22,18,22,18" Spacing="14">

                <VerticalStackLayout Spacing="2">
                    <Label Text="Chọn Tour của bạn"
                           FontSize="32"
                           FontFamily="SpaceGroteskBold"
                           FontAttributes="Bold"
                           TextColor="#1F2937" />
                    <Label Text="{Binding ToursAvailableText}"
                           FontSize="14"
                           TextColor="#98A2B3" />
                </VerticalStackLayout>

                <ActivityIndicator IsVisible="{Binding IsLoading}"
                                   IsRunning="{Binding IsLoading}"
                                   Color="#FF4B4B"
                                   Margin="0,4,0,0" />

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="#C62828"
                       FontSize="13"
                       Margin="0,2,0,6" />

                <CollectionView ItemsSource="{Binding RouteCards}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:RouteCardItem">
                            <Border BackgroundColor="White"
                                    Stroke="#ECEEF2"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 22">
                                <Border.Shadow>
                                    <Shadow Brush="#1A000000" Radius="12" Opacity="0.12" Offset="0,5" />
                                </Border.Shadow>

                                <Grid RowDefinitions="170,Auto">
                                    <Grid>
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        <Border BackgroundColor="#22000000" StrokeThickness="0" />
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          Padding="16,14"
                                          ColumnDefinitions="*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          RowSpacing="8">
                                        <Label Text="{Binding Name}"
                                               FontSize="24"
                                               FontFamily="SpaceGroteskBold"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937" />

                                        <Label Grid.Column="1"
                                               Grid.RowSpan="2"
                                               Text="›"
                                               FontSize="30"
                                               TextColor="#C2C8D0"
                                               VerticalOptions="Center" />

                                        <HorizontalStackLayout Grid.Row="1" Spacing="10">
                                            <Label Text="📍" FontSize="12" TextColor="#98A2B3" />
                                            <Label Text="{Binding StopsText}"
                                                   FontSize="13"
                                                   TextColor="#98A2B3" />
                                            <Label Text="•" FontSize="14" TextColor="#98A2B3" />
                                            <Label Text="{Binding MinutesText, StringFormat='~{0}'}"
                                                   FontSize="13"
                                                   TextColor="#98A2B3" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
