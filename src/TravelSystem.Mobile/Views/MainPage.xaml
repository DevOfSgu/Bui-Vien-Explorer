<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TravelSystem.Mobile.ViewModels"
             x:Class="TravelSystem.Mobile.Views.MainPage"

             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#121212}"
             x:DataType="vm:MainPageViewModel">

    <Shell.TitleView>
        <HorizontalStackLayout Spacing="10" Padding="12,4" VerticalOptions="Center">
            <Border StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}"
                    Padding="2"
                    HeightRequest="36"
                    WidthRequest="36">
                <Image Source="logoapp.png" Aspect="AspectFit"/>
            </Border>
            <Label Text="Bùi Viện Explorer"
                   TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                   FontAttributes="Bold"
                   FontSize="18"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Shell.TitleView>

    <Grid>
        <RefreshView Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding ZoneCards}"
                            SelectionMode="None"
                            Margin="22,18,22,18"
                            VerticalScrollBarVisibility="Never">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="14" Margin="0,0,0,14">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Khám phá Bùi Viện"
                               FontSize="32"
                               FontFamily="SpaceGroteskBold"
                               FontAttributes="Bold"
                               TextColor="#1F2937" />
                        <Label Text="{Binding ZonesAvailableText}"
                               FontSize="14"
                               TextColor="#98A2B3" />
                    </VerticalStackLayout>

                    <Label Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           TextColor="#C62828"
                           FontSize="13"
                           Margin="0,2,0,6" />
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ZoneCardItem">

                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            Stroke="{AppThemeBinding Light=#ECEEF2, Dark=#2D2D2D}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainPageViewModel}}, Path=OpenTourDetailsCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid RowDefinitions="170,Auto">
                            <Grid>
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                <Border BackgroundColor="#22000000" StrokeThickness="0" />
                            </Grid>

                            <Grid Grid.Row="1"
                                  Padding="16,14"
                                  ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="8">
                                <Label Text="{Binding Name}"
                                       FontSize="24"
                                       FontFamily="SpaceGroteskBold"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />

                                <HorizontalStackLayout Grid.Column="1" Spacing="15" VerticalOptions="Center">

                                    <Image Source="arrow_forward_icon.png"                   
                                                WidthRequest="20"
                                                HeightRequest="20"
                                                VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="1" Spacing="10">
                                    <Label Text="📍" FontSize="12" TextColor="#98A2B3" />
                                    <Label Text="{Binding StopsText}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#98A2B3, Dark=#CCCCCC}" />
                                    <Label Text="•" FontSize="14" TextColor="#98A2B3" />
                                    <Label Text="{Binding MinutesText, StringFormat='~{0}'}"
                                           FontSize="13"
                                           TextColor="#98A2B3" />
                                </HorizontalStackLayout>
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Grid x:Name="DetailLoadingOverlay"
              BackgroundColor="#66000000"
              IsVisible="False"
              Opacity="0">
            <VerticalStackLayout Spacing="10"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <ActivityIndicator IsRunning="{Binding NavigatingToDetail}"
                                   Color="White"
                                   WidthRequest="40"
                                   HeightRequest="40" />
                <Label Text="Đang mở chi tiết tour..."
                       TextColor="White"
                       FontSize="14"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
