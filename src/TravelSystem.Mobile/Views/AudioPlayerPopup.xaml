<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TravelSystem.Mobile.ViewModels"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui.MediaElement"
             x:Class="TravelSystem.Mobile.Views.AudioPlayerPopup"
             BackgroundColor="#80000000"
             IsVisible="False">

    <Grid x:Name="RootLayout">
        <!-- MediaElement for MP3 playback (hidden) -->
        <toolkit:MediaElement x:Name="AudioMediaPlayer"
                              ShouldAutoPlay="False"
                              IsVisible="False"
                              PositionChanged="OnMediaPositionChanged"
                              MediaEnded="OnMediaEnded"/>

        <Border VerticalOptions="Center" 
                HorizontalOptions="Center" 
                Margin="20"
                Padding="25"
                BackgroundColor="White"
                WidthRequest="340">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.1"/>
            </Border.Shadow>
            
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="15">
                
                <!-- Close Button -->
                <ImageButton Source="close_icon.png"
                             HorizontalOptions="End"
                             VerticalOptions="Start"
                             WidthRequest="30"
                             HeightRequest="30"
                             Padding="5"
                             Clicked="OnCloseClicked"
                             BackgroundColor="Transparent"/>

                <!-- Zone Image -->
                <Border Grid.Row="1" 
                        HeightRequest="160" 
                        Padding="0" 
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>
                    <Image x:Name="ZoneImage" 
                           Source="app_logo.png"
                           Aspect="AspectFill"/>
                </Border>

                 <StackLayout Grid.Row="2" Spacing="4" Margin="0,0,0,5">
                    <Label x:Name="ZoneTitleLabel" 
                           Text="Sahara Beer Club" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center"/>
                    <Label Text="Audio Guide" 
                           FontSize="14" 
                           TextColor="#7F8C8D" 
                           HorizontalOptions="Center"/>
                </StackLayout>

                <!-- Seek Bar -->
                <Grid Grid.Row="3" Margin="0,5,0,15">
                    <Slider x:Name="AudioSlider"
                            MinimumTrackColor="#3498DB"
                            MaximumTrackColor="#ECF0F1"
                            ThumbColor="#3498DB"
                            DragStarted="OnSliderDragStarted"
                            DragCompleted="OnSliderDragCompleted"
                            ValueChanged="OnSliderValueChanged"/>
                </Grid>

                <HorizontalStackLayout Grid.Row="4" 
                                       HorizontalOptions="Center" 
                                       Spacing="25" 
                                       Margin="0,0,0,15">
                    <ImageButton x:Name="PlayPauseButton" 
                                 Source="play_icon.png"
                                 Clicked="OnPlayPauseClicked"
                                 WidthRequest="65"
                                 HeightRequest="65"
                                 Padding="15"
                                 CornerRadius="32"
                                 BackgroundColor="#3498DB"/>

                    <Button Text="Xem chi tiết"
                            Clicked="OnSeeDetailsClicked"
                            FontSize="16"
                            FontAttributes="Bold"
                            HeightRequest="60"
                            Padding="25,0"
                            CornerRadius="30"
                            BackgroundColor="#2ECC71"
                            TextColor="White"/>
                </HorizontalStackLayout>

                <!-- Speed Selection -->
                <FlexLayout Grid.Row="5" 
                            JustifyContent="Center" 
                            AlignItems="Center" 
                            Wrap="Wrap"
                            Margin="0,0,0,10">
                    <Button Text="0.8x" Clicked="OnSpeedSelected" CommandParameter="0.8" Style="{StaticResource SpeedButtonStyle}"/>
                    <Button Text="1.0x" Clicked="OnSpeedSelected" CommandParameter="1.0" Style="{StaticResource SpeedButtonStyle}" BackgroundColor="#3498DB" TextColor="White"/>
                    <Button Text="1.5x" Clicked="OnSpeedSelected" CommandParameter="1.5" Style="{StaticResource SpeedButtonStyle}"/>
                    <Button Text="2.0x" Clicked="OnSpeedSelected" CommandParameter="2.0" Style="{StaticResource SpeedButtonStyle}"/>
                </FlexLayout>
            </Grid>
        </Border>
    </Grid>

    <ContentView.Resources>
        <ResourceDictionary>
            <Style x:Key="SpeedButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="HeightRequest" Value="32"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="BackgroundColor" Value="#F4F7F9"/>
                <Setter Property="TextColor" Value="#34495E"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>
        </ResourceDictionary>
    </ContentView.Resources>
</ContentView>
