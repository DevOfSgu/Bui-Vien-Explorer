<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TravelSystem.Mobile.ViewModels"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui.MediaElement"
             xmlns:services="clr-namespace:TravelSystem.Mobile.Services"
             x:Class="TravelSystem.Mobile.Views.AudioPlayerPopup"
             BackgroundColor="#80000000"
             IsVisible="False">

    <Grid x:Name="RootLayout">
        <!-- MediaElement for MP3 playback (hidden) -->
        <toolkit:MediaElement x:Name="AudioMediaPlayer"
                              ShouldAutoPlay="False"
                              IsVisible="False"
                              PositionChanged="OnMediaPositionChanged"
                              MediaEnded="OnMediaEnded"/>

        <Border VerticalOptions="Center" 
                HorizontalOptions="Center" 
                Margin="20"
                Padding="25"
                BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkSurface}}"
                WidthRequest="340">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.1"/>
            </Border.Shadow>
            
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="15">
                
                <!-- Header with Close Button -->
                <Grid Grid.Row="0" Margin="0,-10,-10,0">
                    <ImageButton Source="close.png"
                                 HorizontalOptions="End"
                                 VerticalOptions="Start"
                                 WidthRequest="36"
                                 HeightRequest="36"
                                 Padding="8"
                                 CornerRadius="18"
                                 Clicked="OnCloseClicked"
                                 BackgroundColor="Transparent"/>
                </Grid>

                <!-- Zone Image -->
                <Border Grid.Row="1" 
                        HeightRequest="160" 
                        Padding="0" 
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>
                    <Image x:Name="ZoneImage" 
                           Source="app_logo.png"
                           Aspect="AspectFill"/>
                </Border>

                 <StackLayout Grid.Row="2" Spacing="4" Margin="0,0,0,5">
                    <Label x:Name="ZoneTitleLabel" 
                           Text="Sahara Beer Club" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" 
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding [audio_guide], Source={x:Static services:LocalizationManager.Instance}}" 
                           FontSize="14" 
                           TextColor="{AppThemeBinding Light=#7F8C8D, Dark={StaticResource Gray500}}" 
                           HorizontalOptions="Center"/>
                </StackLayout>

                <!-- Seek Bar -->
                <Grid Grid.Row="3" Margin="0,5,0,10">
                    <Slider x:Name="AudioSlider"
                            MinimumTrackColor="{AppThemeBinding Light=#3498DB, Dark={StaticResource DarkAccent}}"
                            MaximumTrackColor="{AppThemeBinding Light=#ECF0F1, Dark=#333333}"
                            ThumbColor="{AppThemeBinding Light=#3498DB, Dark={StaticResource DarkAccent}}"
                            DragStarted="OnSliderDragStarted"
                            DragCompleted="OnSliderDragCompleted"
                            ValueChanged="OnSliderValueChanged"/>
                </Grid>

                <VerticalStackLayout Grid.Row="4" Spacing="20">
                    <!-- Controls: Replay, Play/Pause, Details -->
                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="15">
                        <ImageButton x:Name="ReplayButton"
                                     Grid.Column="0"
                                     Source="replay.png"
                                     Clicked="OnReplayClicked"
                                     WidthRequest="50"
                                     HeightRequest="50"
                                     Padding="12"
                                     CornerRadius="25"
                                     BackgroundColor="{AppThemeBinding Light=#F0F3F5, Dark=#333333}"/>

                        <ImageButton x:Name="PlayPauseButton" 
                                     Grid.Column="1"
                                     Source="play.png"
                                     Clicked="OnPlayPauseClicked"
                                     WidthRequest="65"
                                     HeightRequest="65"
                                     Padding="15"
                                     CornerRadius="32"
                                     BackgroundColor="{AppThemeBinding Light=#3498DB, Dark={StaticResource DarkAccent}}"/>

                        <Button Grid.Column="2"
                                Text="{Binding [audio_view_detail], Source={x:Static services:LocalizationManager.Instance}}"
                                Clicked="OnSeeDetailsClicked"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="65"
                                CornerRadius="32"
                                BackgroundColor="{AppThemeBinding Light=#2ECC71, Dark={StaticResource DarkAccentMuted}}"
                                TextColor="{AppThemeBinding Light=White, Dark={StaticResource DarkAccent}}"/>
                    </Grid>

                    <!-- Speed Selection -->
                    <FlexLayout x:Name="SpeedLayout"
                                JustifyContent="Center" 
                                AlignItems="Center" 
                                Wrap="Wrap"
                                Margin="0,0,0,10">
                        <Button Text="0.8x" Clicked="OnSpeedSelected" CommandParameter="0.8" Style="{StaticResource SpeedButtonStyle}"/>
                        <Button Text="1.0x" Clicked="OnSpeedSelected" CommandParameter="1.0" Style="{StaticResource SpeedButtonStyle}" BackgroundColor="#3498DB" TextColor="White"/>
                        <Button Text="1.5x" Clicked="OnSpeedSelected" CommandParameter="1.5" Style="{StaticResource SpeedButtonStyle}"/>
                        <Button Text="2.0x" Clicked="OnSpeedSelected" CommandParameter="2.0" Style="{StaticResource SpeedButtonStyle}"/>
                    </FlexLayout>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>

    <ContentView.Resources>
        <ResourceDictionary>
            <Style x:Key="SpeedButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="HeightRequest" Value="32"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F4F7F9, Dark=#333333}"/>
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#34495E, Dark=White}"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>
        </ResourceDictionary>
    </ContentView.Resources>
</ContentView>
