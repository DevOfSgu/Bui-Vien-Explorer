<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TravelSystem.Mobile.ViewModels"
             x:Class="TravelSystem.Mobile.Views.SavedPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#121212}"
             Title="Địa điểm đã lưu"
             x:DataType="vm:SavedPageViewModel">

    <Shell.TitleView>
        <HorizontalStackLayout Spacing="10" Padding="12,4" VerticalOptions="Center">
            <Border StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}"
                    Padding="2"
                    HeightRequest="36"
                    WidthRequest="36">
                <Image Source="logoapp.png" Aspect="AspectFit"/>
            </Border>
            <Label Text="Bùi Viện Explorer"
                   TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                   FontAttributes="Bold"
                   FontSize="18"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Shell.TitleView>

    <ContentPage.Behaviors>
        <!-- In a real app, we'd use an EventToCommandBehavior from Toolkit to trigger LoadFavorites on Appearing -->
    </ContentPage.Behaviors>

    <RefreshView Command="{Binding LoadFavoritesCommand}" IsRefreshing="{Binding IsLoading}">
        <Grid RowDefinitions="Auto,*">
            
            <VerticalStackLayout Padding="22,18,22,10" Spacing="2">
                <Label Text="Yêu thích"
                       FontSize="32"
                       FontFamily="SpaceGroteskBold"
                       FontAttributes="Bold"
                       TextColor="#1F2937" />
                <Label Text="Danh sách các địa điểm bạn đã lưu"
                       FontSize="14"
                       TextColor="#98A2B3" />
            </VerticalStackLayout>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="22,0,22,20">
                    
                    <VerticalStackLayout IsVisible="{Binding IsEmpty}" 
                                         VerticalOptions="Center" 
                                         HorizontalOptions="Center" 
                                         Padding="0,100,0,0"
                                         Spacing="15">
                        
                        <Label Text="{Binding EmptyStateMessage}"
                               FontSize="16"
                               TextColor="#98A2B3"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding FavoriteZones}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ZoneCardItem">
                                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                                        Stroke="{AppThemeBinding Light=#ECEEF2, Dark=#2D2D2D}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 22">
                                    <Grid Padding="16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                                        <Border WidthRequest="50" HeightRequest="50"
                                                BackgroundColor="#F3F4F6"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#1F2937" />
                                            <Label Text="{Binding Description}" FontSize="13" TextColor="#98A2B3" MaxLines="1" LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">
                                            <ImageButton Source="favourited.png"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SavedPageViewModel}}, Path=RemoveFavoriteCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Transparent"
                                                    BorderWidth="0"
                                                    WidthRequest="28"
                                                    HeightRequest="28"
                                                    MinimumWidthRequest="0"
                                                    MinimumHeightRequest="0"
                                                    Padding="0" />

                                            <Image Source="arrow_forward_icon.png"                   
                                                    WidthRequest="20"
                                                    HeightRequest="20"
                                                    VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </RefreshView>
</ContentPage>
