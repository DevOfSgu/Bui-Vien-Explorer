<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TravelSystem.Mobile.ViewModels"
             xmlns:services="clr-namespace:TravelSystem.Mobile.Services"
             x:Class="TravelSystem.Mobile.Views.SavedPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#121212}"
             Title="{Binding SavedNavTitle}"
             x:DataType="vm:SavedPageViewModel">

    <Shell.TitleView>
        <HorizontalStackLayout Spacing="10" Padding="12,4" VerticalOptions="Center">
            <Image Source="logoapp_ui.svg"
                   Aspect="AspectFit"
                   HeightRequest="34"
                   WidthRequest="34"
                   VerticalOptions="Center" />
            <Label Text="{Binding [app_name], Source={x:Static services:LocalizationManager.Instance}}"
                   TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                   FontAttributes="Bold"
                   FontSize="18"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Shell.TitleView>

    <ContentPage.Behaviors>
        <!-- In a real app, we'd use an EventToCommandBehavior from Toolkit to trigger LoadFavorites on Appearing -->
    </ContentPage.Behaviors>

    <RefreshView Command="{Binding LoadFavoritesCommand}" IsRefreshing="{Binding IsLoading}">
        <Grid RowDefinitions="Auto,*">
            
            <VerticalStackLayout Padding="22,18,22,10" Spacing="2">
                <Label Text="{Binding SavedTitleText}"
                       FontSize="32"
                       FontFamily="SpaceGroteskBold"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />
                <Label Text="{Binding SavedSubtitleText}"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#98A2B3, Dark={StaticResource Gray500}}" />
            </VerticalStackLayout>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="22,0,22,20">
                    
                    <VerticalStackLayout IsVisible="{Binding IsEmpty}" 
                                         VerticalOptions="Center" 
                                         HorizontalOptions="Center" 
                                         Padding="0,100,0,0"
                                         Spacing="15">
                        
                        <Label Text="{Binding EmptyStateMessage}"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light=#98A2B3, Dark={StaticResource Gray500}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding FavoriteZones}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ZoneCardItem">
                                 <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkSurface}}"
                                         Stroke="{AppThemeBinding Light=#ECEEF2, Dark={StaticResource DarkSurface}}"
                                         StrokeThickness="1"
                                         StrokeShape="RoundRectangle 22">
                                     <Border.GestureRecognizers>
                                         <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenZoneDetailCommand}"
                                                               CommandParameter="{Binding .}" />
                                     </Border.GestureRecognizers>
                                     <Grid Padding="16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                                         <Border WidthRequest="50" HeightRequest="50"
                                                 BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#333333}"
                                                 StrokeThickness="0"
                                                 StrokeShape="RoundRectangle 12">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        </Border>

                                         <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                             <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />
                                             <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light=#98A2B3, Dark={StaticResource Gray500}}" MaxLines="1" LineBreakMode="TailTruncation" />
                                         </VerticalStackLayout>

                                        <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">
                                            <ImageButton Source="favourited.png"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFavoriteCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Transparent"
                                                    BorderWidth="0"
                                                    WidthRequest="28"
                                                    HeightRequest="28"
                                                    MinimumWidthRequest="0"
                                                    MinimumHeightRequest="0"
                                                    Padding="0" />

                                            <Image Source="arrow_forward_icon.svg"                   
                                                    WidthRequest="20"
                                                    HeightRequest="20"
                                                    VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </RefreshView>
</ContentPage>
