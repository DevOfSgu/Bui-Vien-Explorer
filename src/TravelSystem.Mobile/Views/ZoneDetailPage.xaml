<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelSystem.Mobile.Views.ZoneDetailPage"
             xmlns:vm="clr-namespace:TravelSystem.Mobile.ViewModels"
             xmlns:views="clr-namespace:TravelSystem.Mobile.Views"
             xmlns:services="clr-namespace:TravelSystem.Mobile.Services"
             x:DataType="vm:ZoneDetailViewModel"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#000000}"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">

    <AbsoluteLayout>
        <Grid AbsoluteLayout.LayoutFlags="All" AbsoluteLayout.LayoutBounds="0,0,1,1" RowDefinitions="350,*">
            <!-- Hero Image -->
            <Grid Grid.Row="0">
                <Image Source="{Binding ImageUrl}" 
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill"/>

                <!-- Top Overlay Buttons -->
                <Grid VerticalOptions="Start" Padding="20,50,20,0" ColumnDefinitions="Auto,*,Auto,Auto">
                    <Border Grid.Column="0"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="8">
                        <Image Source="arrow_forward_icon.svg" Rotation="180" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <HorizontalStackLayout Grid.Column="2" Spacing="10">
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="8">
                            <Image Source="favourite.svg">
                                <Image.Triggers>
                                    <DataTrigger TargetType="Image" Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Source" Value="favourited.svg" />
                                    </DataTrigger>
                                </Image.Triggers>
                            </Image>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="8">
                            <Image Source="home.svg" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoHomeCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Indicator dots -->
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,20">
                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="White" />
                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="White" Opacity="0.5" />
                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="White" Opacity="0.5" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Bottom Content -->
            <Border Grid.Row="1"
                    Margin="0,-24,0,0"
                    BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#000000}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0">
                <ScrollView Padding="24">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Name}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#111111, Dark=#F5F5F5}"
                                   FontFamily="SpaceGroteskBold" />
                            
                            <Border Grid.Column="1"
                                    BackgroundColor="{Binding OpenStatusBackgroundColor}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="12,6">
                                <Label Text="{Binding OpenStatusText}" TextColor="{Binding OpenStatusTextColor}" FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14" Margin="0,4,0,0">
                            <Border Grid.Column="0"
                                    Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#2A2A2E}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#141417}"
                                    Padding="14">
                                <VerticalStackLayout Spacing="8">
                                    <Image Source="location.svg"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           HorizontalOptions="Start" />
                                    <Label Text="{Binding [zone_address], Source={x:Static services:LocalizationManager.Instance}}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light=#444444, Dark=#8A8A8A}" />
                                    <Label Text="{Binding AddressText}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           LineBreakMode="WordWrap"
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#F5F5F5}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#2A2A2E}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#141417}"
                                    Padding="14">
                                <VerticalStackLayout Spacing="8">
                                    <Image Source="timer.svg"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           HorizontalOptions="Start" />
                                    <Label Text="{Binding [zone_hours], Source={x:Static services:LocalizationManager.Instance}}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light=#444444, Dark=#8A8A8A}" />
                                    <Label Text="{Binding HoursText}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           LineBreakMode="WordWrap"
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#F5F5F5}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#2A2A2E}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#111114}"
                                Padding="16"
                                Margin="0,8,0,0">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding [zone_about], Source={x:Static services:LocalizationManager.Instance}}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#111111, Dark=#F5F5F5}" />
                                <Label Text="{Binding Description}"
                                       FontSize="15"
                                       TextColor="{AppThemeBinding Light=#222222, Dark=#A3A3A3}"
                                       LineHeight="1.5" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>


    </AbsoluteLayout>
</ContentPage>
