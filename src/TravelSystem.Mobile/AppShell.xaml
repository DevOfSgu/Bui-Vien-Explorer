<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TravelSystem.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TravelSystem.Mobile.Views"
    Shell.BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}"
    Shell.ForegroundColor="{AppThemeBinding Light=#111827, Dark=White}"
    Shell.TitleColor="{AppThemeBinding Light=#111827, Dark=White}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#FF4B4B, Dark=#FF4B4B}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#FF4B4B, Dark=#FF4B4B}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#94A3B8, Dark=#94A3B8}"
    Title="Bùi Viện Explorer">

    <TabBar Route="MainTabs">
        <ShellContent
            Title="Home"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Yêu thích"
            Icon="favourite.png"
            ContentTemplate="{DataTemplate views:SavedPage}"
            Route="SavedPage" />


        <ShellContent
            Title="Settings"
            Icon="setting.png"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
