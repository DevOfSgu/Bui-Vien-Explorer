@model IEnumerable<TravelSystem.Shared.Models.Tour>
@{
    ViewData["Title"] = "Quản lý Tour";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="page-title">Quản lý Tour</div>
    <a asp-action="Create" class="btn btn-danger">
        <i class="fa-solid fa-plus me-2"></i>Tạo Tour mới
    </a>
</div>

<div class="card-custom">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="bg-light">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Tên Tour</th>
                    <th>Thời lượng</th>
                    <th>Số điểm dừng</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            Chưa có tour nào được tạo. <a asp-action="Create">Tạo ngay?</a>
                        </td>
                    </tr>
                }
                @foreach (var tour in Model)
                {
                    <tr>
                        <td class="text-muted small">#@tour.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(tour.ImageUrl))
                                {
                                    <img src="@tour.ImageUrl" class="rounded me-3" style="width: 50px; height: 40px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="rounded me-3 bg-light d-flex align-items-center justify-content-center" style="width: 50px; height: 40px;">
                                        <i class="fa-solid fa-map text-muted"></i>
                                    </div>
                                }
                                <div>
                                    <div class="fw-bold">@tour.Name</div>
                                    <div class="text-muted small text-truncate" style="max-width: 300px;">@tour.Description</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark">
                                <i class="fa-regular fa-clock me-1 text-muted"></i> @tour.Duration phút
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-danger rounded-pill">@tour.TourZones.Count POIs</span>
                        </td>
                        <td class="text-muted small">@tour.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@tour.Id" class="btn btn-sm btn-outline-secondary" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger ms-1" title="Xóa" 
                                        onclick="confirmDelete(@tour.Id, '@tour.Name')">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            if (confirm('Bạn có chắc chắn muốn xóa tour "' + name + '" không?')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}
