@model TravelSystem.Shared.Models.Tour
@{
    ViewData["Title"] = "Chỉnh sửa Tour";
    var zones = ViewBag.Zones as IEnumerable<TravelSystem.Shared.Models.Zone>;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style>
    /* Reuse styles from Create or put in shared CSS. For brevity, I'll copy the key ones */
    .tour-creator-container {
        display: grid;
        grid-template-columns: 320px 1fr 320px;
        gap: 20px;
        height: calc(100vh - 160px);
        min-height: 600px;
    }

    .panel-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #edf2f9;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .panel-header {
        padding: 15px 20px;
        border-bottom: 1px solid #edf2f9;
        background-color: #f8fafc;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .panel-title {
        font-weight: 700;
        font-size: 15px;
        margin: 0;
    }

    .panel-body {
        flex-grow: 1;
        overflow-y: auto;
        padding: 15px;
    }

    .zone-item {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #f1f5f9;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #fff;
    }

    .zone-item:hover { border-color: #ef4444; background-color: #fffafb; }
    
    .zone-item.selected {
        border-color: #10b981;
        background-color: #ecfdf5;
        cursor: default;
        position: relative;
    }

    .zone-item.selected::after {
        content: '\f00c';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        position: absolute;
        right: 15px;
        color: #10b981;
    }

    .zone-item.selected:hover {
        background-color: #ecfdf5;
        border-color: #10b981;
    }

    .zone-item.selected i.fa-plus {
        display: none;
    }

    .zone-img { width: 45px; height: 45px; border-radius: 8px; object-fit: cover; background: #f1f5f9; }
    .zone-info { flex-grow: 1; min-width: 0; }
    .zone-name { font-weight: 700; font-size: 13px; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .zone-meta { font-size: 11px; color: #94a3b8; }
    .itinerary-item { position: relative; }
    .itinerary-item .zone-number { width: 24px; height: 24px; background-color: #ef4444; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
    .itinerary-item .remove-btn { color: #cbd5e1; cursor: pointer; transition: color 0.2s; }
    .itinerary-item .remove-btn:hover { color: #ef4444; }
    .form-label-custom { font-weight: 600; font-size: 13px; color: #64748b; margin-bottom: 8px; display: block; }
    .tour-preview-img { width: 100%; height: 180px; border-radius: 12px; background-size: cover; background-position: center; margin-bottom: 15px; display: flex; align-items: center; justify-content: center; border: 2px dashed #e2e8f0; }
    .search-input-container { position: relative; margin-bottom: 15px; }
    .search-input-container i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8; }
    .search-input { padding-left: 35px; font-size: 13px; border-radius: 8px; }
</style>

<form asp-action="Edit" method="post" id="tourForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    
    <div class="header-actions">
        <div>
            <div class="page-title">Chỉnh sửa Tour</div>
            <div class="text-muted small">ID: #@Model.Id • Cập nhật lần cuối: @Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
            <button type="submit" class="btn btn-danger px-4 fw-bold">
                <i class="fa-solid fa-check me-2"></i>Lưu thay đổi
            </button>
        </div>
    </div>

    <div class="tour-creator-container">
        <!-- Left Panel -->
        <div class="panel-card">
            <div class="panel-header">
                <h6 class="panel-title">Điểm tham quan</h6>
                <span class="badge bg-light text-muted fw-normal">Sẵn có</span>
            </div>
            <div class="panel-body">
                <div class="search-input-container">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" class="form-control search-input" id="zoneSearch" placeholder="Tìm kiếm điểm tham quan..." />
                </div>
                 <div id="availableZones">
                    @foreach (var zone in zones)
                    {
                        <div class="zone-item" data-id="@zone.Id" data-name="@zone.Name" id="zone-source-@zone.Id" onclick="addToItinerary(this)">

                            <img src="@(string.IsNullOrEmpty(zone.ImageUrl) ? "https://ui-avatars.com/api/?name="+zone.Name : zone.ImageUrl)" class="zone-img" />
                            <div class="zone-info">
                                <div class="zone-name">@zone.Name</div>
                                <div class="zone-meta">@zone.Radius m • POI</div>
                            </div>
                            <i class="fa-solid fa-plus text-muted small"></i>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Middle Panel -->
        <div class="panel-card" style="background: transparent; border: none;">
            <div class="row g-4 h-100">
                <div class="col-12">
                    <div class="card-custom">
                        <div class="row">
                            <div class="col-md-5">
                                <label class="form-label-custom">Ảnh bìa tour</label>
                                <div id="imagePreview" class="tour-preview-img" style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? $"background-image: url('{Model.ImageUrl}'); border-style: solid;" : "")">
                                    <div class="text-center text-muted" id="previewPlaceholder" style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display: none;" : "")">
                                        <i class="fa-solid fa-image fa-2x mb-2"></i>
                                        <div class="small">Chưa có ảnh</div>
                                    </div>
                                </div>
                                <input asp-for="ImageUrl" class="form-control form-control-sm" placeholder="URL hình ảnh..." id="imageUrlInput" />
                            </div>
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label class="form-label-custom">Tên tour</label>
                                    <input asp-for="Name" class="form-control" required />
                                </div>
                                <div class="mb-4">
                                    <label class="form-label-custom">Mô tả ngắn</label>
                                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                                </div>
                                <div class="row align-items-center">
                                    <div class="col-auto"><label class="form-label-custom mb-0">Thời lượng</label></div>
                                    <div class="col" style="max-width: 150px;">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-regular fa-clock"></i></span>
                                            <input asp-for="Duration" type="number" class="form-control border-start-0" />
                                            <span class="input-group-text bg-white border-start-0 text-muted small">phút</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card-custom h-100" style="padding:0; overflow:hidden; min-height: 250px;">
                        <div id="itineraryMap" style="height: 100%; min-height: 250px; background-color: #f1f5f9; z-index: 1;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="panel-card">
            <div class="panel-header">
                <h6 class="panel-title">Lộ trình tham quan</h6>
                <span class="badge bg-dark rounded-pill" id="poiCount">0 điểm</span>
            </div>
            <div class="panel-body" id="itineraryContainer">
                <div id="emptyItinerary" class="text-center py-5 text-muted" style="display: none;">
                    <i class="fa-solid fa-route fa-3x mb-3 opacity-25"></i>
                    <p class="small">Kéo thả hoặc click (+) để thêm điểm</p>
                </div>
                <div id="sortableItinerary">
                     @foreach (var tz in Model.TourZones.OrderBy(x => x.OrderIndex))
                    {
                        <div class="zone-item itinerary-item" data-id="@tz.ZoneId" data-name="@tz.Zone?.Name" data-source-id="@tz.ZoneId">
                            <div class="zone-number">@tz.OrderIndex</div>
                            <div class="zone-info ms-2">
                                <div class="zone-name">@tz.Zone?.Name</div>
                                <input type="hidden" name="selectedZoneIds" value="@tz.ZoneId" />
                            </div>
                            <i class="fa-solid fa-trash-can remove-btn small" onclick="removeFromItinerary(this)"></i>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        const itineraryContainer = document.getElementById('sortableItinerary');
        const emptyItinerary = document.getElementById('emptyItinerary');
        const poiCountBadge = document.getElementById('poiCount');
        let map;

        function initMap() {
            map = L.map('itineraryMap').setView([10.7688, 106.6924], 16);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 21,
                maxNativeZoom: 19,
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
            }).addTo(map);
        }

        // Initialize map
        setTimeout(initMap, 100);

        new Sortable(itineraryContainer, { animation: 150, ghostClass: 'ghost-item', onSort: updateNumbers });

        function addToItinerary(element) {
            if (element.classList.contains('selected')) return;

            const id = element.getAttribute('data-id');
            const name = element.getAttribute('data-name');
            
            element.classList.add('selected');

            const item = document.createElement('div');
            item.className = 'zone-item itinerary-item';
            item.setAttribute('data-source-id', id);
            item.innerHTML = `
                <div class="zone-number"></div>
                <div class="zone-info ms-2">
                    <div class="zone-name">${name}</div>
                    <input type="hidden" name="selectedZoneIds" value="${id}" />
                </div>
                <i class="fa-solid fa-trash-can remove-btn small" onclick="removeFromItinerary(this)"></i>
            `;
            itineraryContainer.appendChild(item);
            updateNumbers();
        }

        function removeFromItinerary(btn) {
            const item = btn.parentElement;
            const sourceId = item.getAttribute('data-source-id');
            const sourceEl = document.getElementById('zone-source-' + sourceId);
            if (sourceEl) sourceEl.classList.remove('selected');
            item.remove();
            updateNumbers();
        }


        function updateNumbers() {
            const items = itineraryContainer.querySelectorAll('.itinerary-item');
            items.forEach((item, index) => { item.querySelector('.zone-number').innerText = index + 1; });
            const count = items.length;
            poiCountBadge.innerText = `${count} điểm`;
            emptyItinerary.style.display = count > 0 ? 'none' : 'block';
        }

        // Initialize pre-selected zones
        document.querySelectorAll('.itinerary-item').forEach(item => {
            const sourceId = item.getAttribute('data-source-id');
            const sourceEl = document.getElementById('zone-source-' + sourceId);
            if (sourceEl) sourceEl.classList.add('selected');
        });

        updateNumbers(); // Initial count


        document.getElementById('imageUrlInput').addEventListener('input', function() {
            const url = this.value;
            const preview = document.getElementById('imagePreview');
            const placeholder = document.getElementById('previewPlaceholder');
            if (url) { preview.style.backgroundImage = `url('${url}')`; preview.style.borderStyle = 'solid'; placeholder.style.display = 'none'; }
            else { preview.style.backgroundImage = 'none'; preview.style.borderStyle = 'dashed'; placeholder.style.display = 'block'; }
        });

        document.getElementById('zoneSearch').addEventListener('input', function() {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#availableZones .zone-item').forEach(el => {
                const name = el.getAttribute('data-name').toLowerCase();
                el.style.display = name.includes(q) ? 'flex' : 'none';
            });
        });
    </script>
}
