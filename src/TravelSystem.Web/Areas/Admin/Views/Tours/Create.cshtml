@model TravelSystem.Shared.Models.Tour
@{
    ViewData["Title"] = "Tạo Tour mới";
    var zones = ViewBag.Zones as IEnumerable<TravelSystem.Shared.Models.Zone> ?? Enumerable.Empty<TravelSystem.Shared.Models.Zone>();
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style>
    .tour-creator-container {
        display: grid;
        grid-template-columns: 320px 1fr 340px;
        gap: 20px;
        height: calc(100vh - 160px);
        min-height: 500px;
    }

    .panel-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #edf2f9;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .panel-header {
        padding: 15px 20px;
        border-bottom: 1px solid #edf2f9;
        background-color: #f8fafc;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .panel-title {
        font-weight: 700;
        font-size: 15px;
        margin: 0;
    }

    .panel-body {
        flex-grow: 1;
        overflow-y: auto;
        padding: 15px;
    }

    /* List Item Styling */
    .zone-item {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #f1f5f9;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #fff;
    }

    .zone-item:hover {
        border-color: #ef4444;
        background-color: #fffafb;
    }

    .zone-item.selected {
        border-color: #10b981;
        background-color: #ecfdf5;
        cursor: default;
        position: relative;
    }

    .zone-item.selected::after {
        content: '\f00c';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        position: absolute;
        right: 15px;
        color: #10b981;
    }

    .zone-item.selected:hover {
        background-color: #ecfdf5;
        border-color: #10b981;
    }

    .zone-item.selected i.fa-plus {
        display: none;
    }

    .zone-img {
        width: 45px;
        height: 45px;
        border-radius: 8px;
        object-fit: cover;
        background: #f1f5f9;
    }

    .zone-info {
        flex-grow: 1;
        min-width: 0;
    }

    .zone-name {
        font-weight: 700;
        font-size: 13px;
        margin-bottom: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .zone-meta {
        font-size: 11px;
        color: #94a3b8;
    }

    /* Itinerary Styling */
    .itinerary-item {
        position: relative;
        counter-increment: itinerary-counter;
    }

    .itinerary-item .zone-number {
        width: 24px;
        height: 24px;
        background-color: #ef4444;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
    }

    .itinerary-item .remove-btn {
        color: #cbd5e1;
        cursor: pointer;
        transition: color 0.2s;
    }

    .itinerary-item .remove-btn:hover {
        color: #ef4444;
    }

    .ghost-item {
        opacity: 0.5;
        background: #f1f5f9;
    }

    /* Form Styling */
    .form-section {
        margin-bottom: 25px;
    }

    .form-label-custom {
        font-weight: 600;
        font-size: 13px;
        color: #64748b;
        margin-bottom: 8px;
        display: block;
    }

    .tour-preview-img {
        width: 100%;
        height: 180px;
        border-radius: 12px;
        background-color: #f1f5f9;
        background-size: cover;
        background-position: center;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px dashed #e2e8f0;
    }

    .search-input-container {
        position: relative;
        margin-bottom: 15px;
    }

    .search-input-container i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
    }

    .search-input {
        padding-left: 35px;
        font-size: 13px;
        border-radius: 8px;
    }

    .btn-create {
        padding: 10px 24px;
        font-weight: 600;
        border-radius: 10px;
    }

    .form-control-lg {
        font-weight: 700;
        color: #1e293b;
    }

    .input-group-text {
        border-color: #e2e8f0;
        background-color: #f8fafc;
    }

    .input-group .form-control {
        border-color: #e2e8f0;
    }

    .input-group .form-control:focus {
        border-color: #ef4444;
        box-shadow: none;
    }
</style>

<form asp-action="Create" method="post" id="tourForm" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    
    <div class="header-actions">
        <div>
            <div class="page-title">Tạo Tour mới</div>
            <div class="text-muted small">Quản lý thông tin và lộ trình tham quan</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
            <button type="submit" class="btn btn-danger btn-create">
                <i class="fa-solid fa-check me-2"></i>Tạo tour
            </button>
        </div>
    </div>

    <div class="tour-creator-container">
        <!-- Left Panel: Zone Selection -->
        <div class="panel-card">
            <div class="panel-header">
                <h6 class="panel-title">POI</h6>
                <span class="badge bg-light text-muted fw-normal">Sẵn có</span>
            </div>
            <div class="panel-body">
                <div class="search-input-container">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" class="form-control search-input" id="zoneSearch" placeholder="Tìm kiếm POI..." />
                </div>

                <div id="availableZones">
                    @foreach (var zone in zones)
                    {
                        <div class="zone-item" data-id="@zone.Id" data-name="@zone.Name" id="zone-source-@zone.Id" onclick="addToItinerary(this)">

                            @if (!string.IsNullOrEmpty(zone.ImageUrl))
                            {
                                <img src="@zone.ImageUrl" class="zone-img" />
                            }
                            else
                            {
                                <div class="zone-img d-flex align-items-center justify-content-center bg-light">
                                    <i class="fa-solid fa-location-dot text-muted"></i>
                                </div>
                            }
                            <div class="zone-info">
                                <div class="zone-name">@zone.Name</div>
                                <div class="zone-meta">@zone.Radius m • @(zone.ZoneType == 0 ? "Bar" : "Landmark")</div>
                            </div>
                            <i class="fa-solid fa-plus text-muted small"></i>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Middle Panel: Tour Settings -->
        <div class="panel-card" style="padding: 25px;">
            <div class="mb-4">
                <label class="form-label-custom">Ảnh bìa tour</label>
                <div id="imagePreview" class="tour-preview-img">
                    <div class="text-center text-muted" id="previewPlaceholder">
                        <i class="fa-solid fa-image fa-2x mb-2"></i>
                        <div class="small">Chưa có ảnh</div>
                    </div>
                </div>
                <input type="file" name="imageFile" class="form-control form-control-sm" accept="image/*" id="imageInput" onchange="previewImage(this)" />
                <input type="hidden" asp-for="ImageUrl" />
            </div>

            <div class="mb-4">
                <label class="form-label-custom">Tên tour</label>
                <input asp-for="Name" class="form-control form-control-lg" placeholder="Nhập tên tour du lịch..." required />
            </div>

            <div class="mb-4">
                <label class="form-label-custom">Mô tả hành trình</label>
                <textarea asp-for="Description" class="form-control" rows="8" placeholder="Viết một chút về hành trình thú vị này..."></textarea>
            </div>

            <div class="row g-3 align-items-center mb-4">
                <div class="col-auto">
                    <label class="form-label-custom mb-0">Thời lượng dự kiến</label>
                </div>
                <div class="col" style="max-width: 200px;">
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-light"><i class="fa-regular fa-clock text-muted"></i></span>
                        <input asp-for="Duration" type="number" class="form-control text-center fw-bold" value="60" style="height: 42px;" />
                        <span class="input-group-text bg-white text-muted small">phút</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel: Itinerary -->
        <div class="panel-card">
            <div class="panel-header">
                <h6 class="panel-title">Lộ trình tham quan</h6>
                <span class="badge bg-dark rounded-pill" id="poiCount">0 POI</span>
            </div>
            <div class="panel-body" id="itineraryContainer">
                <div id="emptyItinerary" class="text-center py-5 text-muted">
                    <i class="fa-solid fa-route fa-3x mb-3 opacity-25"></i>
                    <p class="small">Kéo thả hoặc click (+) để thêm POI vào lộ trình</p>
                </div>
                
                <div id="sortableItinerary">
                    <!-- Items appended here via JS -->
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        const itineraryContainer = document.getElementById('sortableItinerary');
        const emptyItinerary = document.getElementById('emptyItinerary');
        const poiCountBadge = document.getElementById('poiCount');

        // Initialize Sortable
        const sortable = new Sortable(itineraryContainer, {
            animation: 150,
            ghostClass: 'ghost-item',
            onSort: updateNumbers
        });

        function addToItinerary(element) {
            if (element.classList.contains('selected')) return;

            const id = element.getAttribute('data-id');
            const name = element.getAttribute('data-name');
            const imgSrc = element.querySelector('img')?.src || '';

            element.classList.add('selected');
            
            const item = document.createElement('div');
            item.className = 'zone-item itinerary-item';
            item.setAttribute('data-source-id', id);
            item.innerHTML = `
                <div class="zone-number"></div>
                <div class="zone-info ms-2">
                    <div class="zone-name">${name}</div>
                    <input type="hidden" name="selectedZoneIds" value="${id}" />
                </div>
                <i class="fa-solid fa-trash-can remove-btn small" onclick="removeFromItinerary(this)"></i>
            `;
            
            itineraryContainer.appendChild(item);
            updateNumbers();
        }

        function removeFromItinerary(btn) {
            const item = btn.parentElement;
            const sourceId = item.getAttribute('data-source-id');
            const sourceEl = document.getElementById('zone-source-' + sourceId);
            if (sourceEl) sourceEl.classList.remove('selected');
            item.remove();
            updateNumbers();
        }

        function updateNumbers() {
            const items = itineraryContainer.querySelectorAll('.itinerary-item');
            items.forEach((item, index) => {
                item.querySelector('.zone-number').innerText = index + 1;
            });

            const count = items.length;
            poiCountBadge.innerText = `${count} POI`;
            emptyItinerary.style.display = count > 0 ? 'none' : 'block';
        }

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById('imagePreview');
                    const placeholder = document.getElementById('previewPlaceholder');
                    preview.style.backgroundImage = `url('${e.target.result}')`;
                    preview.style.borderStyle = 'solid';
                    placeholder.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Search Filter
        document.getElementById('zoneSearch').addEventListener('input', function() {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#availableZones .zone-item').forEach(el => {
                const name = el.getAttribute('data-name').toLowerCase();
                el.style.display = name.includes(q) ? 'flex' : 'none';
            });
        });
    </script>
}
