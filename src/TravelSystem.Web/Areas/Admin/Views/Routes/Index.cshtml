@using TravelSystem.Shared.Models
@model IEnumerable<Routes>
@{
    ViewData["Title"] = "Routes Management";
    var counts = ViewBag.ZoneCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="header-actions">
    <div class="page-title">Routes Management</div>
    <a asp-action="Create" class="btn btn-primary-custom" style="text-decoration: none;">
        <i class="fa-solid fa-plus me-2"></i> Add New Route
    </a>
</div>

<div class="card-custom">
    <!-- Filter Row -->
    <div class="d-flex justify-content-between mb-4 pb-3 border-bottom border-light">
        <div class="search-container">
            <i class="fa-solid fa-search"></i>
            <input type="text" class="search-bar" style="width: 400px; background-color: #fff; border: 1px solid #edf2f9;" placeholder="Search routes...">
        </div>
    </div>

    <!-- Data Table -->
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ROUTE NAME</th>
                    <th>IMAGE</th>
                    <th>TOTAL ZONES</th>
                    <th>STATUS</th>
                    <th style="width: 300px;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="@(item.IsHidden ? "opacity: 0.6; background-color: #f5f5f5;" : "")">
                        <td class="text-muted">R-@item.Id.ToString("000")</td>
                        <td>
                            <div class="fw-bold text-dark">@item.Name</div>
                            <small class="text-muted text-truncate d-inline-block" style="max-width:300px;">@item.Description</small>
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="Route image" style="width: 64px; height: 40px; object-fit: cover; border-radius: 6px;" />
                            }
                            else
                            {
                                <span class="badge-soft badge-gray" style="font-family: monospace;">No image</span>
                            }
                        </td>
                        <td>
                            @{
                                int c = counts.ContainsKey(item.Id) ? counts[item.Id] : 0;
                            }
                            <span class="badge-soft badge-red">@c Zones</span>
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                @if(item.IsActive){
                                    <span class="badge-soft" style="background-color: #dcfce7; color: #16a34a;">Active</span>
                                } else {
                                    <span class="badge-soft badge-gray">Draft</span>
                                }
                                @if(item.IsLocked){
                                    <span class="badge-soft" style="background-color: #fee2e2; color: #dc2626;"><i class="fa-solid fa-lock me-1"></i>Locked</span>
                                }
                                @if(item.IsHidden){
                                    <span class="badge-soft" style="background-color: #f3f4f6; color: #6b7280;"><i class="fa-solid fa-eye-slash me-1"></i>Hidden</span>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <!-- View Zones -->
                                <a asp-controller="Zones" asp-action="Index" asp-route-routeId="@item.Id" class="btn btn-sm btn-outline-danger" style="border-radius: 6px; white-space: nowrap;">
                                    <i class="fa-solid fa-map-location-dot me-1"></i> View Zones
                                </a>

                                <!-- Edit -->
                                @if(!item.IsLocked)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" style="border-radius: 6px; white-space: nowrap;">
                                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit
                                    </a>
                                }

                                <!-- Delete -->
                                @if(!item.IsLocked)
                                {
                                    <form method="post" asp-action="Delete" asp-route-id="@item.Id" style="display: inline;" onsubmit="return confirm('Bạn chắc chắn muốn xóa route này?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-trash me-1"></i> Delete
                                        </button>
                                    </form>
                                }

                                <!-- Lock/Unlock -->
                                @if(!item.IsLocked)
                                {
                                    <div class="dropdown" style="display: inline-block;">
                                        <button class="btn btn-sm btn-outline-warning dropdown-toggle" type="button" data-bs-toggle="dropdown" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-ban me-1"></i> Lock
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <form method="post" asp-action="Lock" asp-route-id="@item.Id" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="reason" value="Có vấn đề khi chỉnh sửa">
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="fa-solid fa-exclamation-triangle me-2"></i> Lock: Issues
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <form method="post" asp-action="Unlock" asp-route-id="@item.Id" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-lock-open me-1"></i> Unlock
                                        </button>
                                    </form>
                                }

                                <!-- Hide/Show -->
                                @if(!item.IsHidden)
                                {
                                    <form method="post" asp-action="Hide" asp-route-id="@item.Id" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-eye-slash me-1"></i> Hide
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-action="Show" asp-route-id="@item.Id" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-info" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-eye me-1"></i> Show
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
