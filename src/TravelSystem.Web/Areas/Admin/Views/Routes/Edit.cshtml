@model TravelSystem.Shared.Models.Routes
@{
    ViewData["Title"] = "Edit Route";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Edit Route</div>
    </div>
</div>

<div class="card-custom">
    @if (Model.IsLocked)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong><i class="fa-solid fa-lock me-2"></i>Cảnh báo: Route này đang bị khóa</strong>
            <p class="mb-0 mt-2">Lý do: <strong>@Model.LockReason</strong></p>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label class="form-label fw-bold">Route Name</label>
                    <input asp-for="Name" class="form-control" @(Model.IsLocked ? "disabled" : "") />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4" @(Model.IsLocked ? "disabled" : "")></textarea>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Start Latitude</label>
                        <input asp-for="StartLatitude" type="number" step="0.00000001" class="form-control" @(Model.IsLocked ? "disabled" : "") />
                        <span asp-validation-for="StartLatitude" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Start Longitude</label>
                        <input asp-for="StartLongitude" type="number" step="0.00000001" class="form-control" @(Model.IsLocked ? "disabled" : "") />
                        <span asp-validation-for="StartLongitude" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Image URL</label>
                    <input asp-for="ImageUrl" class="form-control" @(Model.IsLocked ? "disabled" : "") />
                    <small class="text-muted">Optional: URL to route cover image</small>
                </div>
            </div>

            <!-- Settings right sidebar -->
            <div class="col-md-4">
                <div class="p-3 mb-4 rounded" style="background-color: #f8fafc; border: 1px solid #e2e8f0;">
                    <h6 class="fw-bold mb-3"><i class="fa-solid fa-cogs text-primary me-2"></i> Route Settings</h6>
                    
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" @(Model.IsLocked ? "disabled" : "")>
                        <label class="form-check-label fw-bold">Active Route</label>
                    </div>
                    <small class="text-muted d-block mt-2">If active, route will be visible in the mobile app</small>

                    @if (Model.IsLocked)
                    {
                        <div class="alert alert-warning mt-3 p-2">
                            <small><i class="fa-solid fa-lock me-1"></i>Route locked - cannot edit fields</small></div>
                    }
                </div>

                @if (!Model.IsLocked)
                {
                    <button type="submit" class="btn btn-primary-custom w-100 py-2">
                        <i class="fa-solid fa-floppy-disk me-2"></i> Save Changes
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-primary-custom w-100 py-2" disabled>
                        <i class="fa-solid fa-lock me-2"></i> Locked - Cannot Save
                    </button>
                }
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2 mt-2">
                    <i class="fa-solid fa-xmark me-2"></i> Cancel
                </a>
            </div>
        </div>
    </form>
</div>
