@model TravelSystem.Shared.Models.Routes
@{
    ViewData["Title"] = "Add New Route";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Create New Route</div>
    </div>
</div>

<div class="card-custom">
    <form asp-action="Create" method="post">
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label class="form-label fw-bold">Route Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter Route Name" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Description of this route..."></textarea>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Start Latitude</label>
                        <input asp-for="StartLatitude" type="number" step="0.00000001" class="form-control" placeholder="10.7688" required />
                        <span asp-validation-for="StartLatitude" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Start Longitude</label>
                        <input asp-for="StartLongitude" type="number" step="0.00000001" class="form-control" placeholder="106.6924" required />
                        <span asp-validation-for="StartLongitude" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Image URL</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/route-image.jpg" />
                    <small class="text-muted">Optional: URL to route cover image</small>
                </div>
            </div>

            <!-- Settings right sidebar -->
            <div class="col-md-4">
                <div class="p-3 mb-4 rounded" style="background-color: #f8fafc; border: 1px solid #e2e8f0;">
                    <h6 class="fw-bold mb-3"><i class="fa-solid fa-cogs text-primary me-2"></i> Route Settings</h6>
                    
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                        <label class="form-check-label fw-bold">Active Route</label>
                    </div>
                    <small class="text-muted d-block mt-2">If active, route will be visible in the mobile app</small>
                </div>

                <div class="alert alert-info" role="alert">
                    <i class="fa-solid fa-info-circle me-2"></i>
                    <small>Routes are initially <strong>unlocked</strong> and <strong>visible</strong>. You can lock or hide routes later if needed.</small>
                </div>

                <button type="submit" class="btn btn-primary-custom w-100 py-2">
                    <i class="fa-solid fa-check me-2"></i> Create Route
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2 mt-2">
                    <i class="fa-solid fa-xmark me-2"></i> Cancel
                </a>
            </div>
        </div>
    </form>
</div>
