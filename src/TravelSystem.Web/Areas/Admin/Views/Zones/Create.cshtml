@model TravelSystem.Shared.Models.Zone
@{
    ViewData["Title"] = "Thêm POI mới";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Tạo POI (Zone)</div>
    </div>
</div>

<div class="card-custom mb-4">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row">
            <!-- Left Panel: All Inputs -->
            <div class="col-md-4">
                <div class="mb-4">
                    <label class="form-label fw-bold">Tên</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên POI" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả POI này..."></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Ảnh đại diện</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    <small class="text-muted">Tải lên ảnh rõ nét của POI này.</small>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Danh mục (Loại)</label>
                    <select asp-for="ZoneType" class="form-select">
                        <option value="0">Bar & Club</option>
                        <option value="1">Nhà hàng & Quán cà phê</option>
                        <option value="2">Mua sắm</option>
                        <option value="3">Địa danh/Đường phố</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Phân loại POI</label>
                    <select asp-for="IsMain" class="form-select" id="isMainSelect">
                        <option value="true">POI chính</option>
                        <option value="false" selected>POI phụ</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Cửa hàng đối tác liên kết (Tùy chọn)</label>
                    <select asp-for="ShopId" class="form-select" asp-items="@(new SelectList(ViewBag.Shops, "Id", "Name"))">
                        <option value="">-- Không liên kết đối tác / Mốc chung --</option>
                    </select>
                </div>

                <div class="p-3 mb-4 rounded" style="background-color: #f8fafc; border: 1px solid #e2e8f0;">
                    <h6 class="fw-bold mb-3"><i class="fa-solid fa-location-dot text-danger me-2"></i> Cài đặt vị trí</h6>
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small">Vĩ độ</label>
                        <input asp-for="Latitude" type="number" step="0.00000001" class="form-control form-control-sm" placeholder="10.7688" id="latInput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Kinh độ</label>
                        <input asp-for="Longitude" type="number" step="0.00000001" class="form-control form-control-sm" placeholder="106.6924" id="lngInput" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small">Bán kính geo-fence (mét)</label>
                        <input asp-for="Radius" type="number" class="form-control form-control-sm" value="15" id="radiusInput" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small">Thứ tự hiển thị</label>
                        <input asp-for="OrderIndex" type="number" class="form-control form-control-sm" value="1" />
                    </div>

                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                        <label class="form-check-label fw-bold">Đang hoạt động</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary-custom w-100 py-2 mb-2">
                    <i class="fa-solid fa-check me-2"></i> Lưu khu vực
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2">
                    Hủy
                </a>
            </div>

            <!-- Right Panel: Big Map -->
            <div class="col-md-8 d-flex flex-column">
                <div class="position-relative d-flex flex-column" style="flex: 1; min-height: 600px;">
                    <label class="form-label fw-bold">Xem trước bản đồ & chọn vị trí</label>
                    <div id="leafletMap" style="flex: 1; width: 100%; border-radius: 12px; border: 1px solid #edf2f9; z-index: 1;"></div>
                    
                    <div class="map-legend">
                        <div class="legend-item">
                            <div class="dot" style="background: #1e3a8a;"></div>
                            <span>POI chính hiện có</span>
                        </div>
                        <div class="legend-item">
                            <div class="dot" style="background: #f59e0b;"></div>
                            <span>POI phụ hiện có</span>
                        </div>
                        <div class="legend-item">
                            <div class="dot" style="background: #10b981;"></div>
                            <span>POI đang chọn (màu xanh)</span>
                        </div>
                    </div>
                </div>
                <div style="height: 10px;"></div> <!-- Small spacing matching the bottom margin of the left column -->
            </div>
        </div>
    </form>
</div>

<style>
    /* Map Legend */
    .map-legend {
        position: absolute;
        bottom: 40px;
        right: 20px;
        background: white;
        padding: 12px 15px;
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        z-index: 1000;
        font-size: 11px;
        border: 1px solid #edf2f9;
        pointer-events: none;
    }

    .legend-item { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .legend-item:last-child { margin-bottom: 0; }
    .dot { width: 12px; height: 12px; border-radius: 50%; }

    /* Marker Styling */
    .marker-pin {
        width: 30px; height: 30px; border-radius: 50% 50% 50% 0;
        position: absolute; transform: rotate(-45deg);
        left: 50%; top: 50%; margin: -15px 0 0 -15px;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
    .marker-pin i { transform: rotate(45deg); color: white; font-size: 12px; }
</style>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    
    <script>
        let map;
        let pickerMarker;
        let pickerCircle;
        const latInput = document.getElementById('latInput');
        const lngInput = document.getElementById('lngInput');
        const radiusInput = document.getElementById('radiusInput');

        const defaultPos = [10.7688, 106.6924];
        
        const createMarkerIcon = (color, icon = 'fa-location-dot') => {
            return L.divIcon({
                className: 'custom-div-icon',
                html: `<div class="marker-pin" style="background: ${color};"><i class="fa-solid ${icon}"></i></div>`,
                iconSize: [30, 42],
                iconAnchor: [15, 42]
            });
        };

        const icons = {
            main: createMarkerIcon('#1e3a8a', 'fa-star'),
            sub: createMarkerIcon('#f59e0b', 'fa-location-dot'),
            picker: createMarkerIcon('#10b981', 'fa-circle-dot')
        };

        const existingZones = @Html.Raw(Json.Serialize(ViewBag.ExistingZones));

        function initMap() {
            if (!latInput || !lngInput || !radiusInput) return;

            const initialLat = parseFloat(latInput.value) || defaultPos[0];
            const initialLng = parseFloat(lngInput.value) || defaultPos[1];
            const initialRadius = parseInt(radiusInput.value) || 15;
            const pos = [initialLat, initialLng];

            map = L.map('leafletMap').setView(pos, 18);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 21,
                maxNativeZoom: 19
            }).addTo(map);

            if (existingZones) {
                existingZones.forEach(z => {
                    const icon = z.isMain ? icons.main : icons.sub;
                    L.marker([z.latitude, z.longitude], { icon: icon })
                     .bindPopup(`<b>${z.name}</b><br>${z.isMain ? 'POI chính' : 'POI phụ'}`)
                     .addTo(map);
                });
            }

            pickerMarker = L.marker(pos, { draggable: true, icon: icons.picker }).addTo(map);
            pickerCircle = L.circle(pos, {
                radius: initialRadius,
                color: '#10b981',
                fillColor: '#10b981',
                fillOpacity: 0.15,
                weight: 1
            }).addTo(map);

            map.on('click', (e) => updatePosition(e.latlng.lat, e.latlng.lng));
            pickerMarker.on('dragend', () => {
                const p = pickerMarker.getLatLng();
                updatePosition(p.lat, p.lng);
            });

            latInput.addEventListener('change', updateMapFromInputs);
            lngInput.addEventListener('change', updateMapFromInputs);
            radiusInput.addEventListener('input', () => {
                pickerCircle.setRadius(parseInt(radiusInput.value) || 0);
            });
        }

        function updatePosition(lat, lng) {
            pickerMarker.setLatLng([lat, lng]);
            pickerCircle.setLatLng([lat, lng]);
            latInput.value = lat.toFixed(8);
            lngInput.value = lng.toFixed(8);
        }

        function updateMapFromInputs() {
            const lat = parseFloat(latInput.value);
            const lng = parseFloat(lngInput.value);
            if (!isNaN(lat) && !isNaN(lng)) {
                updatePosition(lat, lng);
                map.panTo([lat, lng]);
            }
        }

        setTimeout(initMap, 100);
    </script>
}
