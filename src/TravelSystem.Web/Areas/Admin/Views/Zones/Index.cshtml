@using TravelSystem.Shared.Models
@model IEnumerable<Zone>
@{
    ViewData["Title"] = "Quản lý khu vực";
    var counts = ViewBag.NarrationCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <div class="page-title">Quản lý khu vực</div>
    </div>
    <a asp-action="Create" class="btn btn-primary-custom text-decoration-none">
        <i class="fa-solid fa-plus me-2"></i> Thêm khu vực mới
    </a>
</div>

<div class="card-custom">
    <!-- Filter Row -->
    <div class="d-flex justify-content-between mb-4 pb-3 border-bottom border-light">
        <div class="search-container">
            <i class="fa-solid fa-search"></i>
            <input type="text" class="search-bar" style="width: 400px; background-color: #fff; border: 1px solid #edf2f9;" placeholder="Tìm kiếm khu vực...">
        </div>
        
        <div class="d-flex gap-2">
            <select class="form-select text-muted" style="width: 200px; border-color: #edf2f9; font-size: 14px;">
                <option>Tất cả danh mục</option>
                <option>Bar & Club</option>
                <option>Quán cà phê</option>
                <option>Nhà hàng</option>
                <option>Địa danh</option>
            </select>
            <button class="btn btn-outline-secondary" style="border-color:#edf2f9;"><i class="fa-solid fa-filter text-muted"></i></button>
        </div>
    </div>

    <!-- Data Table -->
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ẢNH ĐẠI DIỆN</th>
                    <th>TÊN KHU VỰC</th>
                    <th>TỌA ĐỘ GPS</th>
                    <th>TỔNG AUDIO GUIDE</th>
                    <th>THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="@(item.IsHidden ? "opacity: 0.6; background-color: #f5f5f5;" : "")">
                        <td class="text-muted">Z-@item.Id.ToString("000")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" width="40" height="40" class="rounded border shadow-sm" style="object-fit: cover;" />
                            }
                            else if (item.ZoneType == 0)
                            {
                                <img src="https://ui-avatars.com/api/?name=@item.Name&background=333&color=fff&rounded=true" width="40" height="40" class="rounded" />
                            }
                            else if (item.ZoneType == 1)
                            {
                                <img src="https://ui-avatars.com/api/?name=@item.Name&background=fcd34d&color=333&rounded=true" width="40" height="40" class="rounded" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center border" style="width:40px; height:40px;">
                                    <i class="fa-regular fa-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@item.Name</div>
                            <small class="text-muted">
                                @(item.ZoneType == 0 ? "Bar & Club" : item.ZoneType == 1 ? "Nhà hàng/Quán cà phê" : "Địa danh")
                            </small>
                            @if(item.IsLocked)
                            {
                                <div style="margin-top: 4px;">
                                    <span class="badge-soft" style="background-color: #fee2e2; color: #dc2626; font-size: 11px;">
                                        <i class="fa-solid fa-lock me-1"></i>Đã khóa
                                    </span>
                                </div>
                            }
                            @if(item.IsHidden)
                            {
                                <div style="margin-top: 4px;">
                                    <span class="badge-soft" style="background-color: #f3f4f6; color: #6b7280; font-size: 11px;">
                                        <i class="fa-solid fa-eye-slash me-1"></i>Đã ẩn
                                    </span>
                                </div>
                            }
                        </td>
                        <td><small class="text-muted" style="font-family: monospace;">@item.Latitude.ToString("0.0000")° N, @item.Longitude.ToString("0.0000")° E</small></td>
                        <td>
                            @{
                                int c = counts.ContainsKey(item.Id) ? counts[item.Id] : 0;
                            }
                            @if(c > 0)
                            {
                                <span class="badge-soft badge-red">@c bản ghi âm</span>
                            }
                            else
                            {
                                <span class="badge-soft badge-gray">0 bản ghi âm</span>
                            }
                        </td>
                        <td style="min-width: 400px;">
                            <div class="d-flex gap-1 flex-wrap">
                                <!-- Scripts -->
                                <a asp-controller="Narrations" asp-action="Index" asp-route-zoneId="@item.Id" class="btn btn-sm btn-outline-danger" style="border-radius: 6px; white-space: nowrap;">
                                    <i class="fa-solid fa-headphones me-1"></i> Kịch bản
                                </a>

                                <!-- Edit -->
                                @if(!item.IsLocked)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px; white-space: nowrap;">
                                        <i class="fa-solid fa-pen"></i> Sửa
                                    </a>
                                }

                                <!-- Delete -->
                                @if(!item.IsLocked)
                                {
                                    <form method="post" asp-action="Delete" asp-route-id="@item.Id" style="display: inline;" onsubmit="return confirm('Bạn chắc chắn muốn xóa zone này?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-trash me-1"></i> Xóa
                                        </button>
                                    </form>
                                }

                                <!-- Lock/Unlock -->
                                @if(!item.IsLocked)
                                {
                                    <div class="dropdown" style="display: inline-block;">
                                        <button class="btn btn-sm btn-outline-warning dropdown-toggle" type="button" data-bs-toggle="dropdown" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-ban me-1"></i> Khóa
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <form method="post" asp-action="Lock" asp-route-id="@item.Id" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="reason" value="Có vấn đề khi chỉnh sửa">
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="fa-solid fa-exclamation-triangle me-2"></i> Khóa: Có vấn đề
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <form method="post" asp-action="Unlock" asp-route-id="@item.Id" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-lock-open me-1"></i> Mở khóa
                                        </button>
                                    </form>
                                }

                                <!-- Hide/Show -->
                                @if(!item.IsHidden)
                                {
                                    <form method="post" asp-action="Hide" asp-route-id="@item.Id" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-eye-slash me-1"></i> Ẩn
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-action="Show" asp-route-id="@item.Id" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-info" style="border-radius: 6px; white-space: nowrap;">
                                            <i class="fa-solid fa-eye me-1"></i> Hiện
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        @{ 
            int currentPage = (int)(ViewBag.Page ?? 1);
            int pageSize = (int)(ViewBag.PageSize ?? 20);
            int totalCount = (int)(ViewBag.TotalCount ?? 0);
            int totalPages = (int)(ViewBag.TotalPages ?? 1);
            int from = (currentPage - 1) * pageSize + 1;
            int to = Math.Min(currentPage * pageSize, totalCount);
        }
        <span class="text-muted" style="font-size: 13px;">Hiển thị <span class="fw-bold text-dark">@from</span> đến <span class="fw-bold text-dark">@to</span> trên tổng <span class="fw-bold text-dark">@totalCount</span> kết quả</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" style="border-color: #edf2f9; color: #94a3b8;">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    if (p == currentPage)
                    {
                        <li class="page-item active" style="--bs-pagination-active-bg: #ef4444; --bs-pagination-active-border-color: #ef4444;">
                            <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@p" style="border-color: #edf2f9; color: #64748b;">@p</a>
                        </li>
                    }
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" style="border-color: #edf2f9; color: #64748b;">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>
