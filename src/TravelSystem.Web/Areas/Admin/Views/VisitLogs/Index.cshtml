@using TravelSystem.Shared.Models
@model IEnumerable<Analytics>
@{
    ViewData["Title"] = "Nhật ký truy cập";

    TimeZoneInfo ResolveVietnamTimeZone()
    {
        try
        {
            return TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time");
        }
        catch (TimeZoneNotFoundException)
        {
            return TimeZoneInfo.FindSystemTimeZoneById("Asia/Ho_Chi_Minh");
        }
    }

    DateTime ToVietnamTime(DateTime dateTime)
    {
        var utc = dateTime.Kind switch
        {
            DateTimeKind.Utc => dateTime,
            DateTimeKind.Local => dateTime.ToUniversalTime(),
            _ => DateTime.SpecifyKind(dateTime, DateTimeKind.Utc)
        };

        return TimeZoneInfo.ConvertTimeFromUtc(utc, ResolveVietnamTimeZone());
    }
}

<div class="header-actions">
    <div class="page-title">Nhật ký khách truy cập</div>
</div>

<div class="card-custom">
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>THỜI GIAN</th>
                    <th>SESSION ID (ẨN DANH)</th>
                    <th>TỌA ĐỘ GPS</th>
                    <th>HÀNH ĐỘNG</th>
                    <th>THỜI GIAN Ở LẠI</th>
                </tr>
            </thead>
            <tbody>
                @if(!Model.Any()) {
                    <tr><td colspan="5" class="text-center text-muted border-bottom-0 pb-4 pt-4">Chưa có dữ liệu truy cập thực tế. Hiển thị dữ liệu mẫu để minh họa giao diện:</td></tr>
                    
                    <!-- Dummy data to show UI layout -->
                    <tr>
                        <td class="text-muted">@(ToVietnamTime(DateTime.UtcNow.AddMinutes(-10)).ToString("dd/MM/yyyy, HH:mm"))</td>
                        <td><span class="badge-soft badge-gray">b9c2a3f1...</span></td>
                        <td><small style="font-family: monospace;">10.7688° N, 106.6924° E</small></td>
                        <td><span class="badge-soft badge-red">PlayNarration</span></td>
                        <td>120s</td>
                    </tr>
                    <tr>
                        <td class="text-muted">@(ToVietnamTime(DateTime.UtcNow.AddMinutes(-25)).ToString("dd/MM/yyyy, HH:mm"))</td>
                        <td><span class="badge-soft badge-gray">f8a91b2c...</span></td>
                        <td><small style="font-family: monospace;">10.7690° N, 106.6920° E</small></td>
                        <td><span class="badge-soft badge-gray">LocationPing</span></td>
                        <td>-</td>
                    </tr>
                    <tr>
                        <td class="text-muted">@(ToVietnamTime(DateTime.UtcNow.AddMinutes(-40)).ToString("dd/MM/yyyy, HH:mm"))</td>
                        <td><span class="badge-soft badge-gray">1a2b3c4d...</span></td>
                        <td><small style="font-family: monospace;">10.7695° N, 106.6918° E</small></td>
                        <td><span class="badge-soft badge-gray">EnterZone</span></td>
                        <td>-</td>
                    </tr>
                }
                @foreach (var log in Model)
                {
                    <tr>
                        <td class="text-muted">@ToVietnamTime(log.CreatedAt).ToString("dd/MM/yyyy, HH:mm")</td>
                        <td><span class="badge-soft badge-gray">@log.SessionId.ToString().Substring(0,8)...</span></td>
                        <td><small style="font-family: monospace;">@log.Latitude.ToString("0.0000")° N, @log.Longitude.ToString("0.0000")° E</small></td>
                        <td>
                            @if(log.ActionType == "PlayNarration"){
                                <span class="badge-soft badge-red">@log.ActionType</span>
                            } else {
                                <span class="badge-soft badge-gray">@log.ActionType</span>
                            }
                        </td>
                        <td>@(log.DwellTimeSeconds > 0 ? log.DwellTimeSeconds + "s" : "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
