@model TravelSystem.Web.Areas.Admin.Models.AdminSettingsViewModel
@{
    ViewData["Title"] = "Cài đặt";
}

<div class="page-title mb-4">Cài đặt</div>

<style>
    .settings-header {
        margin-bottom: 25px;
    }
    .settings-header p {
        color: #64748b;
        margin-bottom: 0;
        font-size: 14px;
        margin-top: 5px;
    }
    .settings-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        border: 1px solid #edf2f9;
        box-shadow: 0 2px 4px -1px rgba(0,0,0,0.02);
        margin-bottom: 24px;
    }
    .form-group label {
        font-size: 12px;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }
    .form-control-custom {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 16px;
        font-size: 14px;
        color: #1f2937;
        width: 100%;
        background-color: #fafaf9;
    }
    .form-control-custom:focus {
        outline: none;
        border-color: #ef4444;
        background-color: #fff;
    }
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 24px;
    }
    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 24px;
    }
    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 18px;
        width: 18px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }
    input:checked + .toggle-slider {
        background-color: #ef4444;
    }
    input:checked + .toggle-slider:before {
        transform: translateX(26px);
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="Index" method="post">
    <div class="settings-card">
        <h5 class="mb-3">Thông tin quản trị viên</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" class="form-control-custom" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control-custom" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control-custom" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
