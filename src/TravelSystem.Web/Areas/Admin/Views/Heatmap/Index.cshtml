@model TravelSystem.Web.Areas.Admin.Controllers.HeatmapController.HeatmapViewModel
@{
    ViewData["Title"] = "Heat map tuyến Bùi Viện";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .heatmap-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .heatmap-badge {
        background: #111827;
        color: #f3f4f6;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .map-wrap {
        position: relative;
    }

    .heatmap-legend {
        position: absolute;
        right: 14px;
        bottom: 14px;
        z-index: 500;
        background: rgba(255, 255, 255, 0.95);
        color: #0f172a;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 12px;
        width: 210px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
        font-size: 12px;
    }

    .heatmap-scale {
        height: 10px;
        border-radius: 999px;
        margin-top: 8px;
        margin-bottom: 6px;
        background: linear-gradient(90deg, #1d4ed8 0%, #06b6d4 28%, #84cc16 48%, #facc15 70%, #ef4444 100%);
    }

    .heatmap-scale-label {
        display: flex;
        justify-content: space-between;
        color: #475569;
    }

    .leaflet-container {
        background: #f8fafc;
    }
</style>

<div class="header-actions">
    <div class="page-title">Heat map dọc tuyến Bùi Viện</div>
</div>

<div class="card-custom">
    <div class="heatmap-meta">
        <span class="heatmap-badge">Start: @Model.StartLatitude, @Model.StartLongitude</span>
        <span class="heatmap-badge">End: @Model.EndLatitude, @Model.EndLongitude</span>
        <span class="heatmap-badge">Corridor: ±@Model.CorridorMeters m</span>
        <span class="heatmap-badge">Analytics: @Model.TotalAnalyticsRows</span>
        <span class="heatmap-badge">Matched: @Model.MatchedRows</span>
    </div>

    <div class="map-wrap">
        <div id="map" style="height: 680px; width: 100%; border-radius: 10px;"></div>
        <div class="heatmap-legend">
            <div><strong>Heat Intensity</strong></div>
            <div style="margin-top:4px;">Dữ liệu được chiếu lên route thật Bùi Viện.</div>
            <div class="heatmap-scale"></div>
            <div class="heatmap-scale-label"><span>min</span><span>max</span></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    <script>
        const routePolyline = @Html.Raw(Json.Serialize(Model.RoutePolyline.Select(p => new[] { p.Latitude, p.Longitude })));
        const heatPoints = @Html.Raw(Json.Serialize(Model.HeatPoints.Select(p => new[] { p.Latitude, p.Longitude, p.Intensity })));

        const map = L.map('map', {
            zoomControl: true,
            preferCanvas: true
        }).setView([10.7529, 106.6873], 15);

        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
        }).addTo(map);

        if (routePolyline && routePolyline.length > 1) {
            const routeBounds = L.latLngBounds(routePolyline);
            map.fitBounds(routeBounds, { padding: [24, 24] });
        }

        if (heatPoints && heatPoints.length > 0) {
            L.heatLayer(heatPoints, {
                radius: 26,
                blur: 20,
                minOpacity: 0.2,
                maxZoom: 18,
                gradient: {
                    0.1: '#1d4ed8',
                    0.3: '#06b6d4',
                    0.5: '#84cc16',
                    0.72: '#facc15',
                    1.0: '#ef4444'
                }
            }).addTo(map);
        }
    </script>
}
