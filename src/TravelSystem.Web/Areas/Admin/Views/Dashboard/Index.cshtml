@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="page-title mb-4">Bảng điều khiển</div>

<!-- Stat Cards Row -->
<div class="row mb-4 g-4">
    <!-- Total Zones -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fa-solid fa-map-location-dot"></i>
            </div>
            <div class="stat-content">
                <p>Tổng POI</p>
                <h4>@ViewBag.TotalZones</h4>
            </div>
        </div>
    </div>

    <!-- Total Narrations -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fce7f3; color: #db2777;">
                <i class="fa-solid fa-wave-square"></i>
            </div>
            <div class="stat-content">
                <p>Tổng bản thuyết minh</p>
                <h4>@ViewBag.TotalNarrations</h4>
            </div>
        </div>
    </div>

    <!-- Active Users -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fee2e2; color: #ef4444;">
                <i class="fa-solid fa-user-group"></i>
            </div>
            <div class="stat-content">
                <p>Người dùng hoạt động hôm nay</p>
                <h4>@ViewBag.ActiveUsers</h4>
            </div>
        </div>
    </div>

    <!-- Average Dwell Time -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fef08a; color: #ca8a04;">
                <i class="fa-solid fa-stopwatch"></i>
            </div>
            <div class="stat-content">
                <p>Thời gian nghe TB / POI</p>
                <h4>@ViewBag.AvgDwellTime<small style="font-size:14px; font-weight:normal; color:#64748b;">s</small></h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Chart Column -->
    <div class="col-xl-8 col-lg-7">
        <div class="card-custom h-100">
            <h6 class="fw-bold mb-4">Lượt truy cập tuần này</h6>
            <div style="height: 300px;">
                <canvas id="weeklyVisitsChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Top POIs Column -->
    <div class="col-xl-4 col-lg-5">
        <div class="card-custom h-100">
            <h6 class="fw-bold mb-4">Top POI nghe nhiều nhất</h6>
            
            <div class="ms-1">
                @{
                    int rank = 1;
                    foreach(var poi in ViewBag.TopPoIs)
                    {
                        var color = rank == 1 ? "text-danger" : (rank == 2 ? "text-warning" : (rank == 3 ? "text-primary" : "text-muted"));
                        <div class="d-flex align-items-center mb-3">
                            <div class="fw-bold @color" style="font-size:18px; width:30px;">#@rank</div>
                            <div class="flex-grow-1 ms-2">
                                <div class="text-dark fw-bold" style="font-size:14px;">@poi.Name</div>
                                <div class="progress mt-1" style="height: 6px;">
                                    <div class="progress-bar bg-danger" role="progressbar" style="width: @(Math.Min(100, (poi.Count * 100) / 500))%" aria-valuenow="@poi.Count" aria-valuemin="0" aria-valuemax="500"></div>
                                </div>
                            </div>
                            <div class="ms-3 text-muted" style="font-size:12px;">@poi.Count <i class="fa-solid fa-headphones"></i></div>
                        </div>
                        rank++;
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Favorites Stats Row -->
<div class="row g-4 mt-1">
    <!-- Total Favorites Stat Card -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fce7f3; color: #db2777;">
                <i class="fa-solid fa-heart"></i>
            </div>
            <div class="stat-content">
                <p>Tổng lượt yêu thích từ khách</p>
                <h4>@ViewBag.TotalFavorites</h4>
            </div>
        </div>
    </div>

    <!-- Top Liked Zones Card -->
    <div class="col-xl-9">
        <div class="card-custom h-100">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="fw-bold mb-0">
                    <i class="fa-solid fa-heart text-danger me-2"></i> Top POI Được Yêu Thích
                </h6>
                <small class="text-muted">Từ guest sessions toàn hệ thống</small>
            </div>

            @if (ViewBag.TopFavorites != null && ((IEnumerable<dynamic>)ViewBag.TopFavorites).Any())
            {
                int fRank = 1;
                foreach (var fav in ((IEnumerable<dynamic>)ViewBag.TopFavorites).Take(5))
                {
                    var fColor = fRank == 1 ? "#ef4444" : (fRank == 2 ? "#f59e0b" : (fRank == 3 ? "#3b82f6" : "#9ca3af"));
                    <div class="d-flex align-items-center mb-3">
                        <div class="fw-bold" style="color:@fColor; font-size:18px; width:32px;">#@fRank</div>
                        <i class="fa-solid fa-location-dot text-muted me-2"></i>
                        <div class="flex-grow-1">
                            <div class="text-dark fw-bold" style="font-size:14px;">@fav.Name</div>
                            <div class="progress mt-1" style="height:6px;">
                                <div class="progress-bar" role="progressbar"
                                     style="width:@(Math.Min(100, (int)((fav.Count * 100) / Math.Max(1, ((IEnumerable<dynamic>)ViewBag.TopFavorites).First().Count))))%; background-color:@fColor;">
                                </div>
                            </div>
                        </div>
                        <div class="ms-3 text-muted" style="font-size:12px;">
                            @fav.Count <i class="fa-solid fa-heart text-danger ms-1"></i>
                        </div>
                    </div>
                    fRank++;
                }
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="fa-regular fa-heart" style="font-size:2rem; margin-bottom:10px; display:block; opacity:0.4;"></i>
                    Chưa có dữ liệu yêu thích. Người dùng chưa thêm POI nào.
                </div>
            }
        </div>
    </div>
</div>

<!-- Dashboard Charts Section -->
<div class="row g-4 mt-2">
    <!-- Shop Owner Registrations -->
    <div class="col-xl-8 col-lg-7">
        <div class="card-custom">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="fw-bold mb-0">Đăng ký chủ cửa hàng (theo tháng)</h6>
                <span class="badge bg-light text-dark fw-normal">Đăng ký hằng tháng</span>
            </div>
            <div style="height: 300px;">
                <canvas id="shopRegChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-lg-5">
        <div class="card-custom h-100">
            <h6 class="fw-bold mb-3">Số liệu hằng ngày (30 ngày)</h6>
            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                <table class="table table-sm table-hover mb-0" style="font-size: 13px;">
                    <thead class="sticky-top bg-white">
                        <tr>
                            <th>Ngày</th>
                            <th class="text-end">Đăng ký</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in (IEnumerable<KeyValuePair<string, int>>)ViewBag.DailyRegTable)
                        {
                            <tr>
                                <td class="text-muted">@item.Key</td>
                                <td class="text-end fw-bold">@item.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <!-- App User Activity -->
    <div class="col-xl-8 col-lg-7">
        <div class="card-custom">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="fw-bold mb-0">Hoạt động người dùng app (session theo tháng)</h6>
                <span class="badge bg-light text-dark fw-normal">Xu hướng người dùng</span>
            </div>
            <div style="height: 300px;">
                <canvas id="appUsageChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-lg-5">
        <div class="card-custom h-100">
            <h6 class="fw-bold mb-3">Số liệu hằng ngày (30 ngày)</h6>
            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                <table class="table table-sm table-hover mb-0" style="font-size: 13px;">
                    <thead class="sticky-top bg-white">
                        <tr>
                            <th>Ngày</th>
                            <th class="text-end">Phiên</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in (IEnumerable<KeyValuePair<string, int>>)ViewBag.DailyUsageTable)
                        {
                            <tr>
                                <td class="text-muted">@item.Key</td>
                                <td class="text-end fw-bold text-primary">@item.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Visits this week chart
        const weeklyVisitsCtx = document.getElementById('weeklyVisitsChart').getContext('2d');
        new Chart(weeklyVisitsCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.WeeklyVisitLabels)),
                datasets: [{
                    label: 'Phiên duy nhất',
                    data: @Html.Raw(Json.Serialize(ViewBag.WeeklyVisitData)),
                    backgroundColor: '#ef4444',
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // Shop Owner Registrations Chart
        const shopRegCtx = document.getElementById('shopRegChart').getContext('2d');
        new Chart(shopRegCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.MonthlyRegLabels)),
                datasets: [{
                    label: 'Lượt đăng ký',
                    data: @Html.Raw(Json.Serialize(ViewBag.MonthlyRegData)),
                    backgroundColor: '#0ea5e9',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // App User Activity Chart
        const appUsageCtx = document.getElementById('appUsageChart').getContext('2d');
        new Chart(appUsageCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.MonthlyUsageLabels)),
                datasets: [{
                    label: 'Phiên duy nhất',
                    data: @Html.Raw(Json.Serialize(ViewBag.MonthlyUsageData)),
                    borderColor: '#f43f5e',
                    backgroundColor: 'rgba(244, 63, 94, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#f43f5e'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}
