@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-title mb-4">Dashboard</div>

<!-- Stat Cards Row -->
<div class="row mb-4 g-4">
    <!-- Total Zones -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fa-solid fa-map-location-dot"></i>
            </div>
            <div class="stat-content">
                <p>Total POIs</p>
                <h4>@ViewBag.TotalZones</h4>
            </div>
        </div>
    </div>

    <!-- Total Narrations -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fce7f3; color: #db2777;">
                <i class="fa-solid fa-wave-square"></i>
            </div>
            <div class="stat-content">
                <p>Total Narrations</p>
                <h4>45</h4>
            </div>
        </div>
    </div>

    <!-- Active Users -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fee2e2; color: #ef4444;">
                <i class="fa-solid fa-user-group"></i>
            </div>
            <div class="stat-content">
                <p>Active Users Today</p>
                <h4>120</h4>
            </div>
        </div>
    </div>

    <!-- Average Dwell Time -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fef08a; color: #ca8a04;">
                <i class="fa-solid fa-stopwatch"></i>
            </div>
            <div class="stat-content">
                <p>Avg. Listen Time / POI</p>
                <h4>@ViewBag.AvgDwellTime<small style="font-size:14px; font-weight:normal; color:#64748b;">s</small></h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Chart Column -->
    <div class="col-xl-8 col-lg-7">
        <div class="card-custom h-100">
            <h6 class="fw-bold mb-4">Visits this week</h6>
            <!-- Placeholder for Chart.js -->
            <div style="height: 300px; display: flex; align-items: flex-end; justify-content: space-around; padding-top: 20px;">
                <!-- CSS Mockup of Bar Chart -->
                <div style="width: 10%; height: 30%; background-color: #fecaca; border-radius: 4px 4px 0 0;"></div>
                <div style="width: 10%; height: 50%; background-color: #fca5a5; border-radius: 4px 4px 0 0;"></div>
                <div style="width: 10%; height: 80%; background-color: #f87171; border-radius: 4px 4px 0 0;"></div>
                <div style="width: 10%; height: 60%; background-color: #fca5a5; border-radius: 4px 4px 0 0;"></div>
                <div style="width: 10%; height: 100%; background-color: #ef4444; border-radius: 4px 4px 0 0;"></div>
                <div style="width: 10%; height: 75%; background-color: #f87171; border-radius: 4px 4px 0 0;"></div>
                <div style="width: 10%; height: 40%; background-color: #fecaca; border-radius: 4px 4px 0 0;"></div>
            </div>
            <div class="d-flex justify-content-space-around mt-3 text-muted" style="font-size: 12px; padding: 0 10px;">
                <span style="flex:1; text-align:center;">Mon</span>
                <span style="flex:1; text-align:center;">Tue</span>
                <span style="flex:1; text-align:center;">Wed</span>
                <span style="flex:1; text-align:center;">Thu</span>
                <span style="flex:1; text-align:center;">Fri</span>
                <span style="flex:1; text-align:center;">Sat</span>
                <span style="flex:1; text-align:center;">Sun</span>
            </div>
        </div>
    </div>

    <!-- Top POIs Column -->
    <div class="col-xl-4 col-lg-5">
        <div class="card-custom h-100">
            <h6 class="fw-bold mb-4">Top POIs (Most Listened)</h6>
            
            <div class="ms-1">
                @{
                    int rank = 1;
                    foreach(var poi in ViewBag.TopPoIs)
                    {
                        var color = rank == 1 ? "text-danger" : (rank == 2 ? "text-warning" : (rank == 3 ? "text-primary" : "text-muted"));
                        <div class="d-flex align-items-center mb-3">
                            <div class="fw-bold @color" style="font-size:18px; width:30px;">#@rank</div>
                            <div class="flex-grow-1 ms-2">
                                <div class="text-dark fw-bold" style="font-size:14px;">@poi.Name</div>
                                <div class="progress mt-1" style="height: 6px;">
                                    <div class="progress-bar bg-danger" role="progressbar" style="width: @(Math.Min(100, (poi.Count * 100) / 500))%" aria-valuenow="@poi.Count" aria-valuemin="0" aria-valuemax="500"></div>
                                </div>
                            </div>
                            <div class="ms-3 text-muted" style="font-size:12px;">@poi.Count <i class="fa-solid fa-headphones"></i></div>
                        </div>
                        rank++;
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Favorites Stats Row -->
<div class="row g-4 mt-1">
    <!-- Total Favorites Stat Card -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #fce7f3; color: #db2777;">
                <i class="fa-solid fa-heart"></i>
            </div>
            <div class="stat-content">
                <p>Total Guest Favorites</p>
                <h4>@ViewBag.TotalFavorites</h4>
            </div>
        </div>
    </div>

    <!-- Top Liked Zones Card -->
    <div class="col-xl-9">
        <div class="card-custom h-100">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="fw-bold mb-0">
                    <i class="fa-solid fa-heart text-danger me-2"></i> Top Địa Điểm Được Yêu Thích
                </h6>
                <small class="text-muted">Từ guest sessions toàn hệ thống</small>
            </div>

            @if (ViewBag.TopFavorites != null && ((IEnumerable<dynamic>)ViewBag.TopFavorites).Any())
            {
                int fRank = 1;
                foreach (var fav in ViewBag.TopFavorites)
                {
                    var fColor = fRank == 1 ? "#ef4444" : (fRank == 2 ? "#f59e0b" : (fRank == 3 ? "#3b82f6" : "#9ca3af"));
                    <div class="d-flex align-items-center mb-3">
                        <div class="fw-bold" style="color:@fColor; font-size:18px; width:32px;">#@fRank</div>
                        <i class="fa-solid fa-location-dot text-muted me-2"></i>
                        <div class="flex-grow-1">
                            <div class="text-dark fw-bold" style="font-size:14px;">@fav.Name</div>
                            <div class="progress mt-1" style="height:6px;">
                                <div class="progress-bar" role="progressbar"
                                     style="width:@(Math.Min(100, (int)((fav.Count * 100) / Math.Max(1, ((IEnumerable<dynamic>)ViewBag.TopFavorites).First().Count))))%; background-color:@fColor;">
                                </div>
                            </div>
                        </div>
                        <div class="ms-3 text-muted" style="font-size:12px;">
                            @fav.Count <i class="fa-solid fa-heart text-danger ms-1"></i>
                        </div>
                    </div>
                    fRank++;
                }
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="fa-regular fa-heart" style="font-size:2rem; margin-bottom:10px; display:block; opacity:0.4;"></i>
                    Chưa có dữ liệu favorites. Người dùng chưa thêm địa điểm yêu thích nào.
                </div>
            }
        </div>
    </div>
</div>
