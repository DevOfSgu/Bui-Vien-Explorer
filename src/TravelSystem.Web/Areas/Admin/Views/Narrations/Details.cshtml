@model TravelSystem.Shared.Models.Narration
@{
    ViewData["Title"] = "Chi tiết thuyết minh";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" asp-route-zoneId="@Model.ZoneId" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Chi tiết thuyết minh</div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger d-flex align-items-center" style="border-radius: 10px;">
        <i class="fa-solid fa-circle-exclamation me-2"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="card-custom">
    <div class="row g-4">
        <div class="col-md-6">
            <label class="form-label fw-bold">Khu vực</label>
            <input type="text" class="form-control" value="@(ViewBag.ZoneName ?? "Không xác định")" readonly />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Ngôn ngữ</label>
            <input type="text" class="form-control" value="@Model.Language" readonly />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Trạng thái</label>
            <input type="text" class="form-control" value="@Model.ApprovalStatus" readonly />
        </div>
    </div>

    <div class="mt-4">
        <label class="form-label fw-bold">Nội dung thuyết minh</label>
        <textarea class="form-control" rows="14" readonly>@Model.Text</textarea>
    </div>

    <div class="mt-4 d-flex gap-2">
        @if (Model.ApprovalStatus == "Pending")
        {
            <form asp-action="Approve" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-check me-1"></i> Duyệt
                </button>
            </form>
            <form asp-action="Reject" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fa-solid fa-xmark me-1"></i> Từ chối
                </button>
            </form>
        }
        else
        {
            <span class="text-muted">Kịch bản này đã ở trạng thái @Model.ApprovalStatus.ToLowerInvariant().</span>
        }
    </div>
</div>
