@using TravelSystem.Shared.Models
@model IEnumerable<Narration>
@{
    ViewData["Title"] = "Âm thanh & thuyết minh";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        @if (ViewBag.SelectedZoneId != null)
        {
            <a asp-controller="Zones" asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div class="page-title">Kịch bản TTS của @(ViewBag.ZoneName ?? "Zone")</div>
        }
        else
        {
            <div class="page-title">Âm thanh & thuyết minh</div>
        }
    </div>
    <div class="badge bg-warning text-dark px-3 py-2" style="font-size: 13px;">
        <i class="fa-solid fa-shield-halved me-1"></i> Chế độ kiểm duyệt
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger d-flex align-items-center" style="border-radius: 10px;">
        <i class="fa-solid fa-circle-exclamation me-2"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="card-custom">
    <!-- Filter Row -->
    <div class="d-flex justify-content-between mb-4 pb-3 border-bottom border-light">
        <div class="search-container">
            <i class="fa-solid fa-search"></i>
            <input type="text" class="search-bar" style="width: 400px; background-color: #fff; border: 1px solid #edf2f9;" placeholder="Tìm kiếm file âm thanh...">
        </div>
        
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="hidden" name="zoneId" value="@ViewBag.SelectedZoneId" />
            <select name="language" class="form-select text-muted" style="width: 200px; border-color: #edf2f9; font-size: 14px;" onchange="this.form.submit()">
                <option value="all" selected="@(ViewBag.SelectedLanguage == "all")">Tất cả ngôn ngữ</option>
                <option value="vi" selected="@(ViewBag.SelectedLanguage == "vi")">Tiếng Việt</option>
                <option value="en" selected="@(ViewBag.SelectedLanguage == "en")">Tiếng Anh</option>
                <option value="ja" selected="@(ViewBag.SelectedLanguage == "ja")">Tiếng Nhật</option>
                <option value="ko" selected="@(ViewBag.SelectedLanguage == "ko")">Tiếng Hàn</option>
            </select>
            <button type="submit" class="btn btn-outline-secondary" style="border-color:#edf2f9;"><i class="fa-solid fa-filter text-muted"></i></button>
        </form>
    </div>

    <!-- Data Table -->
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>KHU VỰC</th>
                    <th>NGÔN NGỮ</th>
                    <th>XEM NHANH NỘI DUNG</th>
                    <th>TRẠNG THÁI</th>
                    <th>THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @if(!Model.Any()) {
                    <tr><td colspan="5" class="text-center text-muted border-bottom-0 pb-4 pt-4">Không tìm thấy kịch bản nào.</td></tr>
                }
                @foreach(var item in Model) {
                    <tr>
                        <td class="text-muted">A-@item.Id.ToString("000")</td>
                        <td>
                            <div class="text-dark fw-bold">@(ViewBag.ZonesMap != null && ViewBag.ZonesMap.ContainsKey(item.ZoneId) ? ViewBag.ZonesMap[item.ZoneId] : "Không xác định")</div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if(item.Language == "vi") { <img src="https://flagcdn.com/w20/vn.png" width="20" alt="VN"> <span class="text-dark">Tiếng Việt</span> }
                                else if(item.Language == "en") { <img src="https://flagcdn.com/w20/gb.png" width="20" alt="UK"> <span class="text-dark">Tiếng Anh</span> }
                                else if(item.Language == "ko") { <img src="https://flagcdn.com/w20/kr.png" width="20" alt="KR"> <span class="text-dark">Tiếng Hàn</span> }
                                else if(item.Language == "ja") { <img src="https://flagcdn.com/w20/jp.png" width="20" alt="JP"> <span class="text-dark">Tiếng Nhật</span> }
                                else { <span class="text-dark">@item.Language</span> }
                            </div>
                        </td>
                        <td class="text-muted"><small>@item.Text.Substring(0, Math.Min(item.Text.Length, 40))...</small></td>
                        <td>
                            @if(item.ApprovalStatus == "Pending") {
                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock"></i> Chờ duyệt</span>
                            } else if (item.ApprovalStatus == "Approved") {
                                <span class="badge bg-success"><i class="fa-solid fa-check"></i> Đã duyệt</span>
                            } else {
                                <span class="badge bg-danger"><i class="fa-solid fa-xmark"></i> Từ chối</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                @if (item.ApprovalStatus == "Pending") {
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px;">
                                        <i class="fa-solid fa-eye"></i> Xem
                                    </a>
                                    <form asp-action="Approve" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit" class="btn btn-sm btn-success js-approve-btn" style="border-radius: 6px;">
                                            <span class="js-approve-idle"><i class="fa-solid fa-check"></i> Duyệt</span>
                                            <span class="js-approve-loading d-none">
                                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                                Đang duyệt...
                                            </span>
                                        </button>
                                    </form>
                                    <form asp-action="Reject" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit" class="btn btn-sm btn-danger" style="border-radius: 6px;">
                                            <i class="fa-solid fa-xmark"></i> Từ chối
                                        </button>
                                    </form>
                                } else if (item.ApprovalStatus == "Approved") {
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px;">
                                        <i class="fa-solid fa-eye"></i> Xem
                                    </a>
                                    <a asp-action="Manage" asp-route-zoneId="@item.ZoneId" class="btn btn-sm btn-primary" style="border-radius: 6px;">
                                        <i class="fa-solid fa-pen"></i> Chỉnh sửa
                                    </a>
                                } else {
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px;">
                                        <i class="fa-solid fa-eye"></i> Xem
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        @{ 
            int currentPage = (int)(ViewBag.Page ?? 1);
            int pageSize = (int)(ViewBag.PageSize ?? 20);
            int totalCount = (int)(ViewBag.TotalCount ?? 0);
            int totalPages = (int)(ViewBag.TotalPages ?? 1);
            int from = (currentPage - 1) * pageSize + 1;
            int to = Math.Min(currentPage * pageSize, totalCount);
        }
        <span class="text-muted" style="font-size: 13px;">Hiển thị <span class="fw-bold text-dark">@from</span> đến <span class="fw-bold text-dark">@to</span> trên tổng <span class="fw-bold text-dark">@totalCount</span> kết quả</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-zoneId="@ViewBag.SelectedZoneId" asp-route-language="@ViewBag.SelectedLanguage" style="border-color: #edf2f9; color: #94a3b8;">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    if (p == currentPage)
                    {
                        <li class="page-item active" style="--bs-pagination-active-bg: #ef4444; --bs-pagination-active-border-color: #ef4444;">
                            <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-zoneId="@ViewBag.SelectedZoneId" asp-route-language="@ViewBag.SelectedLanguage">@p</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-zoneId="@ViewBag.SelectedZoneId" asp-route-language="@ViewBag.SelectedLanguage" style="border-color: #edf2f9; color: #64748b;">@p</a>
                        </li>
                    }
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-zoneId="@ViewBag.SelectedZoneId" asp-route-language="@ViewBag.SelectedLanguage" style="border-color: #edf2f9; color: #64748b;">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="modal fade" id="approvalSuccessModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title text-success fw-bold"><i class="fa-solid fa-circle-check me-2"></i>Thành công</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-2 pb-4">
                    <div class="text-muted">@TempData["Success"]</div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        (function () {
            const approveForms = document.querySelectorAll('form[asp-action="Approve"], form[action*="/Approve"]');
            approveForms.forEach(function (form) {
                form.addEventListener('submit', function () {
                    const button = form.querySelector('.js-approve-btn');
                    if (!button || button.disabled) return;

                    button.disabled = true;
                    const idle = button.querySelector('.js-approve-idle');
                    const loading = button.querySelector('.js-approve-loading');
                    if (idle) idle.classList.add('d-none');
                    if (loading) loading.classList.remove('d-none');
                });
            });

            const successModalEl = document.getElementById('approvalSuccessModal');
            if (successModalEl && typeof bootstrap !== 'undefined') {
                const successModal = new bootstrap.Modal(successModalEl);
                successModal.show();
            }
        })();
    </script>
}
