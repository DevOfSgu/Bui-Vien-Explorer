@model TravelSystem.Shared.Models.Narration
@{
    ViewData["Title"] = "Add New Script";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" asp-route-zoneId="@Model.ZoneId" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Create TTS Script</div>
    </div>
</div>

<div class="card-custom">
    <form asp-action="Create" method="post">
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label class="form-label fw-bold">Select Active Zone (POI)</label>
                    <select asp-for="ZoneId" class="form-select" asp-items="@(new SelectList(ViewBag.Zones, "Id", "Name"))" required>
                        <option value="">-- Choose POI --</option>
                    </select>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Select Language</label>
                        <select asp-for="Language" class="form-select" required>
                            <option value="vi">Vietnamese (vi)</option>
                            <option value="en">English (en)</option>
                            <option value="ko">Korean (ko)</option>
                            <option value="ja">Japanese (ja)</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Narration Text (Script)</label>
                    <textarea asp-for="Text" class="form-control" rows="12" placeholder="Write the script here. This text will be synthesized to speech when a user visits the POI..."></textarea>
                    <small class="text-muted mt-2 d-block">This is the exact string the Text-To-Speech API will read. Use punctuation to control pauses.</small>
                </div>
            </div>

            <!-- Settings Sidebar -->
            <div class="col-md-4">
                <div class="p-3 mb-4 rounded" style="background-color: #f8fafc; border: 1px solid #e2e8f0;">
                    <h6 class="fw-bold mb-3"><i class="fa-solid fa-microphone text-primary me-2"></i> Audio Configuration</h6>
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small">Voice Profile (Optional)</label>
                        <select asp-for="VoiceId" class="form-select form-select-sm">
                            <option value="">-- Let Device Decide --</option>
                            <option value="Wavenet-A">Premium Female (A)</option>
                            <option value="Wavenet-B">Premium Male (B)</option>
                            <option value="Wavenet-C">Premium Female (C)</option>
                            <option value="Wavenet-D">Premium Male (D)</option>
                        </select>
                    </div>

                    <div class="alert alert-info mt-4 pb-0" style="font-size: 13px;">
                        <i class="fa-solid fa-circle-info me-1"></i> If you leave the Voice Profile empty, the mobile device's default System Voice will be used for synthesis.
                    </div>
                </div>

                <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-2">
                    <i class="fa-solid fa-check me-2"></i> Save Script
                </button>
            </div>
        </div>
    </form>
</div>
