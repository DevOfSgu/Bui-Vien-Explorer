@{
    ViewData["Title"] = "Store Settings";
    var shop = ViewBag.Shop as TravelSystem.Shared.Models.Shop ?? new TravelSystem.Shared.Models.Shop();
    var hours = ViewBag.Hours as List<TravelSystem.Shared.Models.ShopHour> ?? new List<TravelSystem.Shared.Models.ShopHour>();
}

<style>
    .settings-header {
        margin-bottom: 25px;
    }
    
    .settings-header p {
        color: #64748b;
        margin-bottom: 0;
        font-size: 14px;
        margin-top: 5px;
    }

    .settings-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        border: 1px solid #edf2f9;
        box-shadow: 0 2px 4px -1px rgba(0,0,0,0.02);
        margin-bottom: 24px;
    }

    .card-title-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }
    
    .card-title-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background-color: #ef4444;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
    }

    .card-title-text {
        font-weight: 700;
        font-size: 16px;
        color: #111827;
        margin: 0;
    }

    .form-group label {
        font-size: 12px;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    .form-control-custom {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 16px;
        font-size: 14px;
        color: #1f2937;
        width: 100%;
        background-color: #fafaf9;
    }

    .form-control-custom:focus {
        outline: none;
        border-color: #ef4444;
        background-color: #fff;
    }

    /* Location & Hours */
    .geo-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 16px;
        background-color: #f8fafc;
        border-radius: 8px;
        margin-bottom: 8px;
        font-size: 13px;
    }

    .geo-label {
        color: #64748b;
    }

    .geo-value {
        color: #1e293b;
        font-family: monospace;
        letter-spacing: 1px;
    }

    .map-placeholder {
        background-color: #e2e8f0;
        border-radius: 12px;
        height: 180px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 24px;
        margin-top: 15px;
    }

    /* Table Hours */
    .hours-table {
        width: 100%;
        font-size: 13px;
    }
    
    .hours-table th {
        color: #64748b;
        font-weight: 500;
        padding-bottom: 12px;
    }
    
    .hours-table td {
        padding: 10px 0;
        color: #111827;
        font-weight: 500;
    }

    .time-input-group {
        position: relative;
        display: inline-block;
        width: 120px;
    }
    
    .time-input-group input {
        width: 100%;
        border: none;
        background-color: #f8fafc;
        padding: 8px 12px;
        border-radius: 6px;
        color: #334155;
    }
    
    .time-input-group i {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #64748b;
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }
    
    .status-open {
        background-color: #dcfce7;
        color: #16a34a;
    }

    .status-closed {
        background-color: #fee2e2;
        color: #dc2626;
    }

    .status-inactive {
        background-color: #e2e8f0;
        color: #475569;
    }

    /* Floating Save Button */
    .floating-save-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background-color: #ef4444;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: 600;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.4);
        transition: 0.2s;
        z-index: 1000;
    }
    
    .floating-save-btn:hover {
        background-color: #dc2626;
        transform: translateY(-2px);
    }

    .password-modal-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    }

    .password-modal-icon {
        width: 56px;
        height: 56px;
        background-color: #ffe8e8;
        color: #ff4d4f;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin: 0 auto 16px;
    }

    .password-input-wrapper {
        position: relative;
    }

    .password-input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #adb5bd;
        z-index: 2;
    }

    .password-input {
        border-radius: 8px;
        padding: 12px 15px 12px 40px;
        border: 1px solid #e9ecef;
        font-size: 0.95rem;
        background-color: #f8f9fa;
    }

    .password-input:focus {
        box-shadow: 0 0 0 3px rgba(255, 77, 79, 0.1);
        border-color: #ff4d4f;
        background-color: #ffffff;
    }

    .btn-password-submit {
        background-color: #ff4d4f;
        border: none;
        border-radius: 8px;
        padding: 12px;
        font-weight: 600;
    }

    .btn-password-submit:hover {
        background-color: #ff3333;
    }
</style>

<div class="settings-header">
    <h3 class="fw-bold mb-0 text-dark">Store Settings</h3>
    <p>Manage your club profile, media, and operating hours.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center" style="border-radius: 10px;">
        <i class="fa-solid fa-circle-check me-2"></i>
        <span>@TempData["Success"]</span>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger d-flex align-items-center" style="border-radius: 10px;">
        <i class="fa-solid fa-circle-exclamation me-2"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<form method="post" asp-action="Index" asp-controller="Settings" asp-area="Vendor" enctype="multipart/form-data">

<!-- Basic Info -->
<div class="settings-card">
    <div class="card-title-row">
        <div class="card-title-icon"><i class="fa-solid fa-info"></i></div>
        <h4 class="card-title-text">Basic Info</h4>
    </div>
    
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="form-group">
                <label>Store Name</label>
                <input type="text" name="shop.Name" class="form-control-custom" value="@shop.Name" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label>Category</label>
                <select name="shop.Category" class="form-control-custom" style="appearance: auto;">
                    <option selected>Bar</option>
                    <option>Restaurant</option>
                    <option>Club</option>
                    <option>Café</option>
                    <option>Ăn uống</option>
                </select>
            </div>
        </div>
    </div>
    
    <div class="form-group">
        <label>Address</label>
        <input type="text" name="shop.Address" class="form-control-custom" value="@shop.Address" placeholder="e.g., 123 Bùi Viện, District 1, HCM" />
    </div>
    
    <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="shop.PhoneNumber" class="form-control-custom" value="@shop.PhoneNumber" placeholder="+84 28 ... " />
    </div>
    
    
</div>

<!-- Location & Hours -->
<div class="settings-card">
    <div class="card-title-row">
        <div class="card-title-icon"><i class="fa-regular fa-clock"></i></div>
        <h4 class="card-title-text">Operating Hours & Location</h4>
    </div>
    
    <div class="row g-5 mb-4">
        
    </div>
    
    <div class="row g-5">
        <div class="col-md-12">
            <div class="form-group">
                <label class="mb-3">Operating Hours</label>
                <table class="hours-table">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Opening Time</th>
                            <th>Closing Time</th>
                            <th class="text-end">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            // Keep 3 editable groups in UI, with safe defaults if DB data is missing.
                            var mondayHour = hours.FirstOrDefault(h => h.DayOfWeek == 1)
                                ?? new TravelSystem.Shared.Models.ShopHour { DayOfWeek = 1, OpenTime = new TimeSpan(8, 0, 0), CloseTime = new TimeSpan(23, 0, 0) };
                            var tueThuHour = hours.FirstOrDefault(h => h.DayOfWeek is >= 2 and <= 4)
                                ?? new TravelSystem.Shared.Models.ShopHour { DayOfWeek = 2, OpenTime = new TimeSpan(8, 0, 0), CloseTime = new TimeSpan(23, 0, 0) };
                            var friSunHour = hours.FirstOrDefault(h => h.DayOfWeek is >= 5 and <= 7)
                                ?? new TravelSystem.Shared.Models.ShopHour { DayOfWeek = 5, OpenTime = new TimeSpan(8, 0, 0), CloseTime = new TimeSpan(23, 0, 0) };

                            var now = DateTime.Now;
                            var today = now.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)now.DayOfWeek;
                            var currentTime = now.TimeOfDay;

                            static bool IsOpenNow(TimeSpan open, TimeSpan close, TimeSpan current)
                            {
                                if (close <= open)
                                {
                                    return current >= open || current < close;
                                }

                                return current >= open && current < close;
                            }

                            static (string Text, string Css) GetStatusLabel(bool appliesToday, bool isOpen)
                            {
                                if (!appliesToday) return ("SCHEDULED", "status-inactive");
                                return isOpen ? ("OPEN", "status-open") : ("CLOSED", "status-closed");
                            }

                            var mondayStatus = GetStatusLabel(
                                appliesToday: today == 1,
                                isOpen: IsOpenNow(mondayHour.OpenTime, mondayHour.CloseTime, currentTime));

                            var tueThuStatus = GetStatusLabel(
                                appliesToday: today is >= 2 and <= 4,
                                isOpen: IsOpenNow(tueThuHour.OpenTime, tueThuHour.CloseTime, currentTime));

                            var friSunStatus = GetStatusLabel(
                                appliesToday: today is >= 5 and <= 7,
                                isOpen: IsOpenNow(friSunHour.OpenTime, friSunHour.CloseTime, currentTime));
                        }
                        <tr>
                            <td>Monday</td>
                            <td>
                                <input type="hidden" name="hours[0].DayOfWeek" value="1" />
                                <input type="time" name="hours[0].OpenTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@mondayHour.OpenTime.ToString(@"hh\:mm")" />
                            </td>
                            <td>
                                <input type="time" name="hours[0].CloseTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@mondayHour.CloseTime.ToString(@"hh\:mm")" />
                            </td>
                            <td class="text-end"><span class="status-badge @mondayStatus.Css">@mondayStatus.Text</span></td>
                        </tr>
                        <tr>
                            <td>Tue - Thu</td>
                            <td>
                                <input type="hidden" name="hours[1].DayOfWeek" value="2" />
                                <input type="time" name="hours[1].OpenTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@tueThuHour.OpenTime.ToString(@"hh\:mm")" />
                            </td>
                            <td>
                                <input type="time" name="hours[1].CloseTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@tueThuHour.CloseTime.ToString(@"hh\:mm")" />
                            </td>
                            <td class="text-end"><span class="status-badge @tueThuStatus.Css">@tueThuStatus.Text</span></td>
                        </tr>
                        <tr>
                            <td>Fri - Sun</td>
                            <td>
                                <input type="hidden" name="hours[2].DayOfWeek" value="5" />
                                <input type="time" name="hours[2].OpenTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@friSunHour.OpenTime.ToString(@"hh\:mm")" />
                            </td>
                            <td>
                                <input type="time" name="hours[2].CloseTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@friSunHour.CloseTime.ToString(@"hh\:mm")" />
                            </td>
                            <td class="text-end"><span class="status-badge @friSunStatus.Css">@friSunStatus.Text</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Security -->
<div class="settings-card">
    <div class="card-title-row">
        <div class="card-title-icon"><i class="fa-solid fa-shield-halved"></i></div>
        <h4 class="card-title-text">Security</h4>
    </div>
    
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h6 class="fw-bold mb-1 text-dark">Manage Access</h6>
            <p class="text-muted mb-0" style="font-size: 13px;">Update your account password or manage store visibility.</p>
        </div>
        <div class="d-flex gap-4 align-items-center">
            <button type="button"
                    class="btn border fw-bold text-dark"
                    style="background-color: #f8fafc; font-size: 13px;"
                    data-bs-toggle="modal"
                    data-bs-target="#changePasswordModal">
                Change Password
            </button>
            <a href="#" class="text-decoration-none" style="color: #94a3b8; font-size: 13px;">Deactivate Store</a>
        </div>
    </div>
</div>

<!-- Floating Save Button -->
<button type="submit" class="floating-save-btn">
    <i class="fa-regular fa-floppy-disk"></i> Save Changes
</button>
</form>

<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content password-modal-card">
            <div class="modal-body p-4 p-md-5">
                <div class="password-modal-icon">
                    <i class="fa-solid fa-lock"></i>
                </div>
                <h5 class="fw-bold text-center mb-1">Change Password</h5>
                <p class="text-muted text-center mb-4" style="font-size: 0.92rem;">
                    Update your account password to keep your vendor portal secure.
                </p>

                @if (TempData["ChangePasswordError"] != null)
                {
                    <div class="alert alert-danger py-2" style="border-radius: 8px; font-size: 0.9rem;">
                        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ChangePasswordError"]
                    </div>
                }

                <form method="post" asp-action="ChangePassword" asp-controller="Settings" asp-area="Vendor">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Current Password</label>
                        <div class="password-input-wrapper">
                            <i class="fa-solid fa-lock password-input-icon"></i>
                            <input type="password" name="currentPassword" class="form-control password-input" placeholder="Enter current password" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <div class="password-input-wrapper">
                            <i class="fa-solid fa-key password-input-icon"></i>
                            <input type="password" name="newPassword" class="form-control password-input" placeholder="Enter new password" required minlength="6" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Confirm New Password</label>
                        <div class="password-input-wrapper">
                            <i class="fa-solid fa-key password-input-icon"></i>
                            <input type="password" name="confirmPassword" class="form-control password-input" placeholder="Confirm new password" required minlength="6" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light w-50 border" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-password-submit text-white w-50">Update Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (TempData["OpenChangePasswordModal"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalEl = document.getElementById("changePasswordModal");
            if (!modalEl) return;
            var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();
        });
    </script>
}

