@{
    ViewData["Title"] = "Store Settings";
    var shop = ViewBag.Shop as TravelSystem.Shared.Models.Shop ?? new TravelSystem.Shared.Models.Shop();
    var hours = ViewBag.Hours as List<TravelSystem.Shared.Models.ShopHour> ?? new List<TravelSystem.Shared.Models.ShopHour>();
}

<style>
    .settings-header {
        margin-bottom: 25px;
    }
    
    .settings-header p {
        color: #64748b;
        margin-bottom: 0;
        font-size: 14px;
        margin-top: 5px;
    }

    .settings-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        border: 1px solid #edf2f9;
        box-shadow: 0 2px 4px -1px rgba(0,0,0,0.02);
        margin-bottom: 24px;
    }

    .card-title-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }
    
    .card-title-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background-color: #ef4444;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
    }

    .card-title-text {
        font-weight: 700;
        font-size: 16px;
        color: #111827;
        margin: 0;
    }

    .form-group label {
        font-size: 12px;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    .form-control-custom {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 16px;
        font-size: 14px;
        color: #1f2937;
        width: 100%;
        background-color: #fafaf9;
    }

    .form-control-custom:focus {
        outline: none;
        border-color: #ef4444;
        background-color: #fff;
    }

    /* Media Upload Area */
    .upload-box {
        background-color: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .upload-logo {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        margin-bottom: 10px;
    }

    .upload-icon-overlay {
        position: absolute;
        bottom: 5px;
        right: 15px;
        background-color: #ef4444;
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        border: 2px solid white;
        cursor: pointer;
    }

    .upload-helper-text {
        font-size: 10px;
        color: #94a3b8;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-top: 15px;
    }

    .upload-gallery-add {
        width: 140px;
        height: 140px;
        border-radius: 12px;
    }

    .upload-gallery-add i {
        color: #94a3b8;
        font-size: 24px;
        margin-bottom: 8px;
    }

    .upload-gallery-add span {
        font-size: 11px;
        color: #94a3b8;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .gallery-preview {
        width: 140px;
        height: 140px;
        border-radius: 12px;
        object-fit: cover;
    }

    /* Location & Hours */
    .geo-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 16px;
        background-color: #f8fafc;
        border-radius: 8px;
        margin-bottom: 8px;
        font-size: 13px;
    }

    .geo-label {
        color: #64748b;
    }

    .geo-value {
        color: #1e293b;
        font-family: monospace;
        letter-spacing: 1px;
    }

    .map-placeholder {
        background-color: #e2e8f0;
        border-radius: 12px;
        height: 180px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 24px;
        margin-top: 15px;
    }

    /* Table Hours */
    .hours-table {
        width: 100%;
        font-size: 13px;
    }
    
    .hours-table th {
        color: #64748b;
        font-weight: 500;
        padding-bottom: 12px;
    }
    
    .hours-table td {
        padding: 10px 0;
        color: #111827;
        font-weight: 500;
    }

    .time-input-group {
        position: relative;
        display: inline-block;
        width: 120px;
    }
    
    .time-input-group input {
        width: 100%;
        border: none;
        background-color: #f8fafc;
        padding: 8px 12px;
        border-radius: 6px;
        color: #334155;
    }
    
    .time-input-group i {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #64748b;
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }
    
    .status-open {
        background-color: #dcfce7;
        color: #16a34a;
    }

    /* Floating Save Button */
    .floating-save-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background-color: #ef4444;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: 600;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.4);
        transition: 0.2s;
        z-index: 1000;
    }
    
    .floating-save-btn:hover {
        background-color: #dc2626;
        transform: translateY(-2px);
    }
</style>

<div class="settings-header">
    <h3 class="fw-bold mb-0 text-dark">Store Settings</h3>
    <p>Manage your club profile, media, and operating hours.</p>
</div>

<form method="post" asp-action="Index" asp-controller="Settings" asp-area="Vendor" enctype="multipart/form-data">

<!-- Basic Info -->
<div class="settings-card">
    <div class="card-title-row">
        <div class="card-title-icon"><i class="fa-solid fa-info"></i></div>
        <h4 class="card-title-text">Basic Info</h4>
    </div>
    
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="form-group">
                <label>Store Name</label>
                <input type="text" name="shop.Name" class="form-control-custom" value="@shop.Name" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label>Category</label>
                <select name="shop.Category" class="form-control-custom" style="appearance: auto;">
                    <option selected>Bar</option>
                    <option>Restaurant</option>
                    <option>Club</option>
                    <option>Café</option>
                </select>
            </div>
        </div>
    </div>
    
    <div class="form-group">
        <label>Address</label>
        <input type="text" name="shop.Address" class="form-control-custom" value="@shop.Address" placeholder="e.g., 123 Bùi Viện, District 1, HCM" />
    </div>
    
    <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="shop.PhoneNumber" class="form-control-custom" value="@shop.PhoneNumber" placeholder="+84 28 ... " />
    </div>
    
    
</div>

<!-- Media -->
<div class="settings-card">
    <div class="card-title-row">
        <div class="card-title-icon"><i class="fa-regular fa-image"></i></div>
        <h4 class="card-title-text">Media</h4>
    </div>
    
    <div class="row g-4">
        <div class="col-md-3">
            <div class="form-group">
                <label>Store Logo</label>
                <div class="d-flex flex-column align-items-center mt-2">
                    <div class="position-relative" style="cursor: pointer;" onclick="document.getElementById('logoInput').click();">
                        <div class="upload-box upload-logo" id="logoPreview">
                            @if (!string.IsNullOrEmpty(shop.ImageUrl))
                            {
                                <img src="@shop.ImageUrl" class="upload-logo" style="margin-bottom: 0; object-fit: cover;" alt="Logo" />
                            }
                            else
                            {
                                <i class="fa-solid fa-store" style="font-size: 30px; color: #94a3b8;"></i>
                            }
                        </div>
                        <div class="upload-icon-overlay">
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                        </div>
                    </div>
                    <input type="file" id="logoInput" name="logoFile" accept="image/png,image/jpeg" style="display: none;" onchange="handleLogoUpload(event)" />
                    <span class="upload-helper-text">PNG, JPG UP TO 2MB</span>
                </div>
            </div>
        </div>
        
        <div class="col-md-9">
            <div class="form-group">
                <label>Store Gallery</label>
                <div class="d-flex gap-3 flex-wrap mt-2" id="galleryContainer">
                    <div class="upload-box upload-gallery-add flex-column" style="cursor: pointer;" onclick="document.getElementById('galleryInput').click();">
                        <i class="fa-regular fa-image"></i>
                        <span class="text-uppercase">Add Photo</span>
                    </div>
                    <input type="file" id="galleryInput" accept="image/png,image/jpeg" multiple style="display: none;" onchange="handleGalleryUpload(event)" />
                    <!-- Images will be listed here after being added -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Location & Hours -->
<div class="settings-card">
    <div class="card-title-row">
        <div class="card-title-icon"><i class="fa-regular fa-clock"></i></div>
        <h4 class="card-title-text">Operating Hours & Location</h4>
    </div>
    
    <div class="row g-5 mb-4">
        
    </div>
    
    <div class="row g-5">
        <div class="col-md-12">
            <div class="form-group">
                <label class="mb-3">Operating Hours</label>
                <table class="hours-table">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Opening Time</th>
                            <th>Closing Time</th>
                            <th class="text-end">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            string[] days = { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };
                            string[] dayRanges = { "Sunday", "Monday", "Tue - Wed", "Tue - Wed", "Tue - Wed", "Fri", "Fri - Sat" };
                            
                            // Group hours by day
                            var mondayHour = hours.FirstOrDefault(h => h.DayOfWeek == 1);
                            var tueThuHour = hours.FirstOrDefault(h => h.DayOfWeek == 2);
                            var friSunHour = hours.FirstOrDefault(h => h.DayOfWeek == 5);
                        }
                        
                        @if (mondayHour != null)
                        {
                            <tr>
                                <td>Monday</td>
                                <td>
                                    <input type="time" name="hours[0].OpenTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@mondayHour.OpenTime.ToString(@"hh\:mm")" />
                                </td>
                                <td>
                                    <input type="time" name="hours[0].CloseTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@mondayHour.CloseTime.ToString(@"hh\:mm")" />
                                </td>
                                <td class="text-end"><span class="status-badge status-open">OPEN</span></td>
                            </tr>
                        }
                        
                        @if (tueThuHour != null)
                        {
                            <tr>
                                <td>Tue - Thu</td>
                                <td>
                                    <input type="time" name="hours[1].OpenTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@tueThuHour.OpenTime.ToString(@"hh\:mm")" />
                                </td>
                                <td>
                                    <input type="time" name="hours[1].CloseTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@tueThuHour.CloseTime.ToString(@"hh\:mm")" />
                                </td>
                                <td class="text-end"><span class="status-badge status-open">OPEN</span></td>
                            </tr>
                        }
                        
                        @if (friSunHour != null)
                        {
                            <tr>
                                <td>Fri - Sun</td>
                                <td>
                                    <input type="time" name="hours[2].OpenTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@friSunHour.OpenTime.ToString(@"hh\:mm")" />
                                </td>
                                <td>
                                    <input type="time" name="hours[2].CloseTime" class="form-control-custom" style="width: 120px; border: 1px solid #e2e8f0; padding: 8px; border-radius: 6px;" value="@friSunHour.CloseTime.ToString(@"hh\:mm")" />
                                </td>
                                <td class="text-end"><span class="status-badge status-open">OPEN</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Security -->
<div class="settings-card">
    <div class="card-title-row">
        <div class="card-title-icon"><i class="fa-solid fa-shield-halved"></i></div>
        <h4 class="card-title-text">Security</h4>
    </div>
    
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h6 class="fw-bold mb-1 text-dark">Manage Access</h6>
            <p class="text-muted mb-0" style="font-size: 13px;">Update your account password or manage store visibility.</p>
        </div>
        <div class="d-flex gap-4 align-items-center">
            <button class="btn border fw-bold text-dark" style="background-color: #f8fafc; font-size: 13px;">Change Password</button>
            <a href="#" class="text-decoration-none" style="color: #94a3b8; font-size: 13px;">Deactivate Store</a>
        </div>
    </div>
</div>

<!-- Floating Save Button -->
<button type="submit" class="floating-save-btn">
    <i class="fa-regular fa-floppy-disk"></i> Save Changes
</button>
</form>

<script>
    function handleLogoUpload(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const logoPreview = document.getElementById('logoPreview');
                logoPreview.innerHTML = '<img src="' + e.target.result + '" class="upload-logo" style="border-radius: 50%; margin-bottom: 0;" alt="Logo Preview" />';
                const overlay = document.createElement('div');
                overlay.className = 'upload-icon-overlay';
                overlay.innerHTML = '<i class="fa-solid fa-cloud-arrow-up"></i>';
                logoPreview.appendChild(overlay);
            };
            reader.readAsDataURL(file);
        }
    }

    function handleGalleryUpload(event) {
        const files = event.target.files;
        if (files) {
            const galleryContainer = document.getElementById('galleryContainer');
            for (let i = 0; i < files.length; i++) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'gallery-preview';
                    img.alt = 'Gallery Image ' + (i + 1);
                    galleryContainer.appendChild(img);
                };
                reader.readAsDataURL(files[i]);
            }
        }
        event.target.value = '';
    }
</script>
