@{
    ViewData["Title"] = "Dashboard Home";
}

<style>
    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 20px;
        border: 1px solid #f0f0f0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: #fee2e2;
        color: #ef4444;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }
    .stat-icon.green { background: #d1fae5; color: #059669; }
    .stat-icon.blue { background: #dbeafe; color: #2563eb; }
    .stat-icon.orange { background: #ffedd5; color: #ea580c; }
    .stat-badge-green {
        font-size: 11px;
        font-weight: 700;
        color: #16a34a;
        background: #dcfce7;
        padding: 3px 8px;
        border-radius: 20px;
    }
    .stat-label { color: #9ca3af; font-size: 13px; font-weight: 500; margin-top: 14px; margin-bottom: 4px; }
    .stat-value { font-size: 28px; font-weight: 700; color: #111827; margin: 0; }
    .stat-compare { color: #9ca3af; font-size: 12px; margin-top: 4px; }

    /* Chart card */
    .chart-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #f0f0f0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        padding: 24px;
    }
    .btn-outline-sm {
        font-size: 12px;
        font-weight: 500;
        color: #6b7280;
        border: 1px solid #e5e7eb;
        background: transparent;
        padding: 5px 12px;
        border-radius: 8px;
        cursor: pointer;
    }
    .btn-outline-sm:hover { background: #f9fafb; }

    /* Language breakdown */
    .lang-item { display: flex; flex-direction: column; align-items: flex-start; }
    .lang-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 6px; }
    .lang-pct { font-size: 26px; font-weight: 700; color: #111827; }
    .lang-count { font-size: 12px; color: #9ca3af; }

    /* Donut chart */
    .donut-wrapper { position: relative; width: 140px; height: 140px; }
    .donut-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
    }
    .donut-center .pct { font-size: 22px; font-weight: 700; color: #111827; }
    .donut-center .lbl { font-size: 10px; color: #9ca3af; font-weight: 600; letter-spacing: 0.5px; }

    /* Open/Closed status */
    .status-open { background: #ef4444; color: #fff; border: none; border-radius: 6px; padding: 5px 14px; font-size: 13px; font-weight: 600; }
    .status-closed { background: #f3f4f6; color: #6b7280; border: 1px solid #e5e7eb; border-radius: 6px; padding: 5px 14px; font-size: 13px; font-weight: 600; }
</style>

<!-- Page header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0" style="color:#111827;font-size:1.2rem;">Dashboard Home</h5>
    <div class="d-flex align-items-center gap-2">
        <button class="status-open">Open</button>
        <button class="status-closed">Closed</button>
        <button class="btn p-2" style="border:none;background:transparent;color:#9ca3af;font-size:18px;"><i class="fa-regular fa-bell"></i></button>
        <div style="width:36px;height:36px;border-radius:50%;background:#f3f4f6;border:1px solid #e5e7eb;"></div>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="stat-icon"><i class="fa-solid fa-location-dot"></i></div>
                <span class="stat-badge-green">+12%</span>
            </div>
            <div class="stat-label">Zone Visits</div>
            <h3 class="stat-value">245</h3>
            <div class="stat-compare">vs yesterday</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="stat-icon green"><i class="fa-solid fa-headphones"></i></div>
            </div>
            <div class="stat-label">Narration Listens</div>
            <h3 class="stat-value">128</h3>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="stat-icon blue"><i class="fa-solid fa-chart-line"></i></div>
            </div>
            <div class="stat-label">Engagement Rate</div>
            <h3 class="stat-value">52%</h3>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="stat-icon orange"><i class="fa-regular fa-clock"></i></div>
            </div>
            <div class="stat-label">Avg. Dwell Time</div>
            <h3 class="stat-value">12m 30s</h3>
        </div>
    </div>
</div>

<!-- Traffic Trends Chart -->
<div class="chart-card mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h6 class="fw-bold mb-1" style="color:#111827;">Customer Traffic Trends</h6>
            <small class="text-muted">Weekly scan volume analysis</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn-outline-sm">Last 7 Days</button>
            <button class="btn-outline-sm">Export</button>
        </div>
    </div>

    <!-- SVG area chart mimicking the mockup -->
    <div style="position:relative; width:100%; height:220px;">
        <svg width="100%" height="100%" viewBox="0 0 800 220" preserveAspectRatio="none">
            <defs>
                <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#ef4444" stop-opacity="0.18"/>
                    <stop offset="100%" stop-color="#ef4444" stop-opacity="0.01"/>
                </linearGradient>
            </defs>
            <!-- Filled area -->
            <path d="M0 190 C100 180, 150 160, 250 140 S400 120, 480 130 S600 160, 680 80 L800 40 L800 220 L0 220 Z"
                  fill="url(#areaGrad)"/>
            <!-- Line -->
            <path d="M0 190 C100 180, 150 160, 250 140 S400 120, 480 130 S600 160, 680 80 L800 40"
                  fill="none" stroke="#ef4444" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <!-- Day labels -->
        <div class="d-flex justify-content-between" style="position:absolute;bottom:0;left:0;right:0;padding: 0 5px;">
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">MON</span>
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">TUE</span>
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">WED</span>
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">THU</span>
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">FRI</span>
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">SAT</span>
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">SUN</span>
        </div>
    </div>
</div>

<!-- Tourist Language Breakdown -->
<div class="chart-card mb-4">
    <div class="mb-3">
        <h6 class="fw-bold mb-1" style="color:#111827;">Tourist Language Breakdown</h6>
        <small class="text-muted">Visitor language distribution analysis</small>
    </div>

    <div class="d-flex align-items-center gap-5 flex-wrap">
        <!-- Donut -->
        <div class="donut-wrapper flex-shrink-0">
            <svg width="140" height="140" viewBox="0 0 140 140">
                <!-- Background ring -->
                <circle cx="70" cy="70" r="52" fill="none" stroke="#f3f4f6" stroke-width="18"/>
                <!-- English 55% = ~198deg -->
                <circle cx="70" cy="70" r="52" fill="none" stroke="#ef4444" stroke-width="18"
                        stroke-dasharray="198 328" stroke-dashoffset="82" stroke-linecap="butt"/>
                <!-- Vietnamese 30% = ~108deg -->
                <circle cx="70" cy="70" r="52" fill="none" stroke="#6b7280" stroke-width="18"
                        stroke-dasharray="108 328" stroke-dashoffset="-116" stroke-linecap="butt"/>
                <!-- Korean 15% = ~54deg - pinkish -->
                <circle cx="70" cy="70" r="52" fill="none" stroke="#fca5a5" stroke-width="18"
                        stroke-dasharray="54 328" stroke-dashoffset="-224" stroke-linecap="butt"/>
            </svg>
            <div class="donut-center">
                <div class="pct">100%</div>
                <div class="lbl">TOTAL SCANS</div>
            </div>
        </div>

        <!-- Legend -->
        <div class="d-flex gap-5 flex-wrap">
            <div class="lang-item">
                <div class="mb-1"><span class="lang-dot" style="background:#ef4444;"></span>🇺🇸 <strong>English</strong></div>
                <div class="lang-pct">55%</div>
                <div class="lang-count">352 Scans</div>
            </div>
            <div class="lang-item">
                <div class="mb-1"><span class="lang-dot" style="background:#6b7280;"></span>🇻🇳 <strong>Vietnamese</strong></div>
                <div class="lang-pct">30%</div>
                <div class="lang-count">192 Scans</div>
            </div>
            <div class="lang-item">
                <div class="mb-1"><span class="lang-dot" style="background:#fca5a5;"></span>🇰🇷 <strong>Korean</strong></div>
                <div class="lang-pct">15%</div>
                <div class="lang-count">96 Scans</div>
            </div>
        </div>
    </div>
</div>
