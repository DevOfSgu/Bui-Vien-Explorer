@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vendor Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">Vendor Portal</span>
            <div class="d-flex text-white align-items-center">
                <span class="me-3">Xin chào, @User.Identity?.Name!</span>
                <a asp-area="Vendor" asp-controller="Auth" asp-action="Logout" class="btn btn-outline-light btn-sm">Đăng xuất</a>
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        <h2>Dashboard Quản Trản Cửa Hàng</h2>
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card bg-info text-white mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Kịch bản TTS</h5>
                        <p class="card-text">Quản lý và cập nhật lời thoại cho cửa hàng của bạn.</p>
                        <a href="#" class="btn btn-light">Go</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-warning text-dark mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Thống Kê</h5>
                        <p class="card-text">Xem lượt ghé thăm và lượt nghe tại cửa hàng.</p>
                        <a href="#" class="btn btn-light">Go</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
