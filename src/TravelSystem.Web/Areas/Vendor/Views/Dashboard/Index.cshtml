@using System.Globalization
@using TravelSystem.Web.Areas.Vendor.Controllers
@{
    ViewData["Title"] = "Dashboard Home";

    var zoneVisits = (int)(ViewBag.ZoneVisits ?? 0);
    var narrationListens = (int)(ViewBag.NarrationListens ?? 0);
    var engagementRate = (int)(ViewBag.EngagementRate ?? 0);
    var avgDwellSeconds = (int)(ViewBag.AvgDwellTimeSeconds ?? 0);
    var avgDwell = TimeSpan.FromSeconds(avgDwellSeconds);
    var avgDwellLabel = $"{(int)avgDwell.TotalMinutes}m {avgDwell.Seconds}s";

    var trafficLabels = (ViewBag.TrafficLabels as List<string>) ?? new List<string> { "MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN" };
    var trafficValues = (ViewBag.TrafficValues as List<int>) ?? new List<int> { 0, 0, 0, 0, 0, 0, 0 };

    if (trafficLabels.Count != trafficValues.Count)
    {
        trafficLabels = new List<string> { "MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN" };
        trafficValues = new List<int> { 0, 0, 0, 0, 0, 0, 0 };
    }

    const double chartWidth = 800;
    const double chartHeight = 220;
    const double baselineY = 190;
    const double topY = 30;
    var maxTraffic = Math.Max(trafficValues.DefaultIfEmpty(0).Max(), 1);

    string F(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    var points = new List<(double X, double Y)>();
    for (var i = 0; i < trafficValues.Count; i++)
    {
        var x = trafficValues.Count == 1 ? 0 : i * (chartWidth / (trafficValues.Count - 1));
        var normalized = trafficValues[i] / (double)maxTraffic;
        var y = baselineY - ((baselineY - topY) * normalized);
        points.Add((x, y));
    }

    var linePath = points.Count > 0
        ? "M " + string.Join(" L ", points.Select(p => $"{F(p.X)} {F(p.Y)}"))
        : "M 0 190";
    var areaPath = points.Count > 0
        ? $"{linePath} L {F(chartWidth)} {F(chartHeight)} L 0 {F(chartHeight)} Z"
        : $"M 0 {F(chartHeight)} L {F(chartWidth)} {F(chartHeight)} Z";

    var languageStats = (ViewBag.LanguageStats as List<DashboardController.LanguageBreakdownViewModel>)
        ?? new List<DashboardController.LanguageBreakdownViewModel>();
    var totalLanguageScans = (int)(ViewBag.TotalLanguageScans ?? 0);

    var circumference = 328d;
    var donutStats = languageStats.Where(x => x.Percentage > 0).ToList();
    var donutOffset = 0d;
}

<style>
    .status-open { background: #ef4444; color: #fff; border: none; border-radius: 999px; padding: 6px 16px; font-size: 12px; font-weight: 600; }
    .status-closed { background: #f3f4f6; color: #6b7280; border: 1px solid #e5e7eb; border-radius: 999px; padding: 6px 16px; font-size: 12px; font-weight: 600; }

    .donut-wrapper { position: relative; width: 140px; height: 140px; }
    .donut-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; }
    .donut-center .pct { font-size: 18px; font-weight: 700; color: #111827; }
    .donut-center .lbl { font-size: 10px; color: #9ca3af; font-weight: 600; letter-spacing: 0.5px; }

    .lang-item { display: flex; flex-direction: column; align-items: flex-start; min-width: 170px; }
    .lang-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 6px; }
    .lang-pct { font-size: 26px; font-weight: 700; color: #111827; }
    .lang-count { font-size: 12px; color: #9ca3af; }
</style>

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div class="stat-content">
                <p>Zone Visits</p>
                <h4>@zoneVisits</h4>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-headphones"></i></div>
            <div class="stat-content">
                <p>Narration Listens</p>
                <h4>@narrationListens</h4>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa-solid fa-chart-line"></i></div>
            <div class="stat-content">
                <p>Engagement Rate</p>
                <h4>@engagementRate<span style="font-size:14px;color:#64748b;">%</span></h4>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fa-regular fa-clock"></i></div>
            <div class="stat-content">
                <p>Avg. Dwell Time</p>
                <h4>@avgDwellLabel</h4>
            </div>
        </div>
    </div>
</div>

<div class="card-custom mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h6 class="fw-bold mb-1" style="color:#111827;">Customer Traffic Trends</h6>
            <small class="text-muted">Weekly scan volume analysis</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" type="button" disabled>Last 7 Days</button>
            <button class="btn btn-outline-secondary btn-sm" type="button" disabled>Export</button>
        </div>
    </div>

    <div style="position:relative; width:100%; height:220px;">
        <svg width="100%" height="100%" viewBox="0 0 800 220" preserveAspectRatio="none">
            <defs>
                <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#ef4444" stop-opacity="0.18"/>
                    <stop offset="100%" stop-color="#ef4444" stop-opacity="0.01"/>
                </linearGradient>
            </defs>
            <path d="@areaPath" fill="url(#areaGrad)"/>
            <path d="@linePath" fill="none" stroke="#ef4444" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="d-flex justify-content-between" style="position:absolute;bottom:0;left:0;right:0;padding: 0 5px;">
            @foreach (var label in trafficLabels)
            {
                <span style="font-size:11px;font-weight:600;color:#9ca3af;">@label</span>
            }
        </div>
    </div>
</div>

<div class="card-custom mb-4">
    <div class="mb-3">
        <h6 class="fw-bold mb-1" style="color:#111827;">Tourist Language Breakdown</h6>
        <small class="text-muted">Visitor language distribution analysis</small>
    </div>

    <div class="d-flex align-items-center gap-5 flex-wrap">
        <div class="donut-wrapper flex-shrink-0">
            <svg width="140" height="140" viewBox="0 0 140 140">
                <circle cx="70" cy="70" r="52" fill="none" stroke="#f3f4f6" stroke-width="18"/>
                @foreach (var stat in donutStats)
                {
                    var arc = stat.Percentage / 100d * circumference;
                    var dashArray = $"{F(arc)} {F(circumference)}";
                    var dashOffset = F(-donutOffset);
                    donutOffset += arc;
                    <circle cx="70" cy="70" r="52" fill="none" stroke="@stat.Color" stroke-width="18"
                            stroke-dasharray="@dashArray"
                            stroke-dashoffset="@dashOffset"
                            transform="rotate(-90 70 70)"/>
                }
            </svg>
            <div class="donut-center">
                <div class="pct">@(totalLanguageScans > 0 ? "100%" : "0%")</div>
                <div class="lbl">TOTAL SCANS</div>
            </div>
        </div>

        <div class="d-flex gap-5 flex-wrap">
            @foreach (var stat in languageStats)
            {
                <div class="lang-item">
                    <div class="mb-1"><span class="lang-dot" style="background:@stat.Color;"></span>@stat.CountryCode <strong>@stat.Name</strong></div>
                    <div class="lang-pct">@stat.Percentage%</div>
                    <div class="lang-count">@stat.Count Scans</div>
                </div>
            }
        </div>
    </div>
</div>
