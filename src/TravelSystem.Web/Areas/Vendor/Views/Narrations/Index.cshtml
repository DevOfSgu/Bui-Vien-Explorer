@using TravelSystem.Shared.Models
@model IEnumerable<Narration>
@{
    ViewData["Title"] = "Audio & Narrations";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        @if (ViewBag.SelectedZoneId != null)
        {
            <div class="page-title">TTS Scripts for @(ViewBag.ZoneName ?? "Zone")</div>
        }
        else
        {
            <div class="page-title">Audio & Narrations</div>
        }
    </div>
    <a asp-action="Create" asp-route-zoneId="@ViewBag.SelectedZoneId" class="btn btn-primary-custom text-decoration-none">
        <i class="fa-solid fa-plus me-2"></i> Add Script
    </a>
</div>

<div class="card-custom">
    <!-- Filter Row -->
    <div class="d-flex justify-content-between mb-4 pb-3 border-bottom border-light">
        <div class="search-container">
            <i class="fa-solid fa-search"></i>
            <input type="text" class="search-bar" style="width: 400px; background-color: #fff; border: 1px solid #edf2f9;" placeholder="Search audio files...">
        </div>
        
        <div class="d-flex gap-2">
            <select class="form-select text-muted" style="width: 200px; border-color: #edf2f9; font-size: 14px;">
                <option>All Languages</option>
                <option>English</option>
                <option>Vietnamese</option>
                <option>Korean</option>
            </select>
            <button class="btn btn-outline-secondary" style="border-color:#edf2f9;"><i class="fa-solid fa-filter text-muted"></i></button>
        </div>
    </div>

    <!-- Data Table -->
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ASSIGNED ZONE</th>
                    <th>LANGUAGE</th>
                    <th>SCRIPT PREVIEW</th>
                    <th>STATUS</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if(!Model.Any()) {
                    <tr><td colspan="5" class="text-center text-muted border-bottom-0 pb-4 pt-4">No scripts found. Add a new script to start.</td></tr>
                }
                @foreach(var item in Model) {
                    <tr>
                        <td class="text-muted">A-@item.Id.ToString("000")</td>
                        <td>
                            <div class="text-dark fw-bold">@(ViewBag.ZonesMap != null && ViewBag.ZonesMap.ContainsKey(item.ZoneId) ? ViewBag.ZonesMap[item.ZoneId] : "Unknown")</div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if(item.Language == "vi") { <img src="https://flagcdn.com/w20/vn.png" width="20" alt="VN"> <span class="text-dark">Vietnamese</span> }
                                else if(item.Language == "en") { <img src="https://flagcdn.com/w20/gb.png" width="20" alt="UK"> <span class="text-dark">English</span> }
                                else if(item.Language == "ko") { <img src="https://flagcdn.com/w20/kr.png" width="20" alt="KR"> <span class="text-dark">Korean</span> }
                                else if(item.Language == "ja") { <img src="https://flagcdn.com/w20/jp.png" width="20" alt="JP"> <span class="text-dark">Japanese</span> }
                                else { <span class="text-dark">@item.Language</span> }
                            </div>
                        </td>
                        <td class="text-muted"><small>@item.Text.Substring(0, Math.Min(item.Text.Length, 40))...</small></td>
                        <td>
                            @if(item.ApprovalStatus == "Pending") {
                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock"></i> Pending Approval</span>
                            } else if (item.ApprovalStatus == "Approved") {
                                <span class="badge bg-success"><i class="fa-solid fa-check"></i> Approved</span>
                            } else {
                                <span class="badge bg-danger"><i class="fa-solid fa-xmark"></i> Rejected</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px;">
                                <i class="fa-solid fa-pen"></i> Edit Task
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <span class="text-muted" style="font-size: 13px;">Showing <span class="fw-bold text-dark">1</span> to <span class="fw-bold text-dark">3</span> of <span class="fw-bold text-dark">12</span> results</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled"><a class="page-link" href="#" style="border-color: #edf2f9; color: #94a3b8;"><i class="fa-solid fa-chevron-left"></i></a></li>
                <li class="page-item active" style="--bs-pagination-active-bg: #ef4444; --bs-pagination-active-border-color: #ef4444;"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#" style="border-color: #edf2f9; color: #64748b;">2</a></li>
                <li class="page-item"><a class="page-link" href="#" style="border-color: #edf2f9; color: #64748b;">3</a></li>
                <li class="page-item disabled"><a class="page-link" href="#" style="border-color: #edf2f9; color: #64748b;">...</a></li>
                <li class="page-item"><a class="page-link" href="#" style="border-color: #edf2f9; color: #64748b;"><i class="fa-solid fa-chevron-right"></i></a></li>
            </ul>
        </nav>
    </div>
</div>
