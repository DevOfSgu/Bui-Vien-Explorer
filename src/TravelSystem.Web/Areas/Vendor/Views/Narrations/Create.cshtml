@model TravelSystem.Shared.Models.Narration
@{
    ViewData["Title"] = "Add New Script";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" asp-route-zoneId="@Model.ZoneId" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Create TTS Script</div>
    </div>
</div>

<div class="card-custom">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center" style="border-radius: 10px;">
            <i class="fa-solid fa-circle-exclamation me-2"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    @if (ViewBag.NoAvailableZone == true)
    {
        <div class="alert alert-warning d-flex align-items-center" style="border-radius: 10px;">
            <i class="fa-solid fa-circle-info me-2"></i>
            <span>All your POIs already have scripts. Use Edit to resubmit updates.</span>
        </div>
    }

    <form asp-action="Create" method="post">
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label class="form-label fw-bold">Select Active Zone (POI)</label>
                    @if (ViewBag.NoAvailableZone == true)
                    {
                        <select asp-for="ZoneId"
                                class="form-select"
                                asp-items="@(new SelectList(ViewBag.Zones, "Id", "Name"))"
                                required
                                disabled>
                            <option value="">-- Choose POI --</option>
                        </select>
                    }
                    else
                    {
                        <select asp-for="ZoneId"
                                class="form-select"
                                asp-items="@(new SelectList(ViewBag.Zones, "Id", "Name"))"
                                required>
                            <option value="">-- Choose POI --</option>
                        </select>
                    }
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Source Language</label>
                        <input type="text" class="form-control" value="Vietnamese (vi)" readonly />
                        <input type="hidden" asp-for="Language" value="vi" />
                        <small class="text-muted">English/Japanese will be generated after admin approval.</small>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Narration Text (Script)</label>
                    <textarea asp-for="Text" class="form-control" rows="12" placeholder="Write the script here. This text will be synthesized to speech when a user visits the POI..."></textarea>
                    <small class="text-muted mt-2 d-block">This is the exact string the Text-To-Speech API will read. Use punctuation to control pauses.</small>
                </div>
            </div>

            <!-- Settings Sidebar -->
            <div class="col-md-4">


                @if (ViewBag.NoAvailableZone == true)
                {
                    <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-2" disabled>
                        <i class="fa-solid fa-check me-2"></i> Save Script
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-2">
                        <i class="fa-solid fa-check me-2"></i> Save Script
                    </button>
                }
            </div>
        </div>
    </form>
</div>
