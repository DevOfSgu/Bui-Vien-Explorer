@model TravelSystem.Shared.Models.Narration
@{
    ViewData["Title"] = "Edit Script";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" asp-route-zoneId="@Model.ZoneId" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Edit TTS Script</div>
    </div>
</div>

<div class="card-custom">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center" style="border-radius: 10px;">
            <i class="fa-solid fa-circle-exclamation me-2"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ZoneId" />
        <input type="hidden" asp-for="Language" value="vi" />
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label class="form-label fw-bold">Select Active Zone (POI)</label>
                    <select asp-for="ZoneId" class="form-select" asp-items="@(new SelectList(ViewBag.Zones, "Id", "Name", Model.ZoneId))" disabled>
                    </select>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Source Language</label>
                        <input type="text" class="form-control" value="Vietnamese (vi)" readonly />
                        <small class="text-muted">Only Vietnamese source script can be edited by vendor.</small>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Narration Text (Script)</label>
                    <textarea asp-for="Text" class="form-control" rows="12"></textarea>
                </div>
            </div>

            <!-- Settings Sidebar -->
            <div class="col-md-4">


                <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-2">
                    <i class="fa-solid fa-floppy-disk me-2"></i> Update Script
                </button>
            </div>
        </div>
    </form>
</div>
