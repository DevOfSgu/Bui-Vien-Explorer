@model TravelSystem.Shared.Models.Narration
@{
    ViewData["Title"] = "Edit Script";
}

<div class="header-actions">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" asp-route-zoneId="@Model.ZoneId" class="btn btn-outline-secondary" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="page-title">Edit TTS Script</div>
    </div>
</div>

<div class="card-custom">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label class="form-label fw-bold">Select Active Zone (POI)</label>
                    <select asp-for="ZoneId" class="form-select" asp-items="@(new SelectList(ViewBag.Zones, "Id", "Name", Model.ZoneId))" required>
                    </select>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Select Language</label>
                        <select asp-for="Language" class="form-select" required>
                            <option value="vi">Vietnamese (vi)</option>
                            <option value="en">English (en)</option>
                            <option value="ko">Korean (ko)</option>
                            <option value="ja">Japanese (ja)</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Narration Text (Script)</label>
                    <textarea asp-for="Text" class="form-control" rows="12"></textarea>
                </div>
            </div>

            <!-- Settings Sidebar -->
            <div class="col-md-4">


                <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-2">
                    <i class="fa-solid fa-floppy-disk me-2"></i> Update Script
                </button>
            </div>
        </div>
    </form>
</div>
