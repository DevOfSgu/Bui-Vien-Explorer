<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelSystem.Web</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/png" href="~/icons/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TravelSystem.Web.styles.css" asp-append-version="true" />
    <style>
        /* Custom Modern Layout Styles */
        @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap');
        
        body {
            font-family: 'Be Vietnam Pro', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin-bottom: 0 !important; /* Ghi đè margin mặc định của site.css */
        }
        main {
            flex: 1;
            width: 100%;
        }
        
        /* Professional Navbar */
        .navbar-premium {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
            padding: 12px 0;
            transition: all 0.3s ease;
        }
        .navbar-premium .navbar-brand {
            font-weight: 800;
            font-size: 1.4rem;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.5px;
        }
        .navbar-premium .navbar-brand:hover {
            color: #ea580c;
        }
        .navbar-premium .nav-link {
            font-weight: 500;
            color: #475569;
            padding: 8px 16px !important;
            border-radius: 8px;
            transition: all 0.2s ease;
            margin: 0 4px;
        }
        .navbar-premium .nav-link:hover, .navbar-premium .nav-link.active {
            color: #ea580c;
            background-color: #ffedd5;
        }

        /* Professional Footer */
        .footer-premium {
            background-color: #0f172a;
            color: #94a3b8;
            padding: 30px 0;
            margin-top: auto; /* Pushes footer to bottom */
        }
        .footer-premium .footer-brand {
            font-weight: 700;
            font-size: 1.2rem;
            color: #fff;
            margin-bottom: 5px;
        }
        .footer-premium a {
            color: #cbd5e1;
            text-decoration: none;
            transition: color 0.2s ease;
        }
        .footer-premium a:hover {
            color: #38bdf8;
            text-decoration: underline;
        }
        .footer-divider {
            border-color: #334155;
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-premium mb-0">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
                    Bùi Viện Explorer
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1 d-flex flex-column">
        <main role="main" class="flex-grow-1 d-flex flex-column">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-premium">
        <div class="container text-center text-md-start">
            <div class="row align-items-center">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="footer-brand">Bùi Viện Explorer App</div>
                    <div>Hành trình thông minh, trải nghiệm trọn vẹn.</div>
                </div>
                <div class="col-md-6 text-md-end">
                    <ul class="list-inline mb-0">
                        <li class="list-inline-item me-4"><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="list-inline-item"><a href="#">Hỗ trợ</a></li>
                    </ul>
                </div>
            </div>
            <hr class="footer-divider" />
            <div class="text-center small">
                &copy; 2026 - Bản quyền thuộc về Bùi Viện Explorer Team
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>