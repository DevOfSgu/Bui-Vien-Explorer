@{
    ViewData["Title"] = "Trang Chủ - Giới thiệu App";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

    .app-landing-wrapper {
        font-family: 'Outfit', sans-serif;
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        overflow-x: hidden;
        background-color: #f8fafc;
        margin-top: -16px; /* Offset to connect with layout header if needed */
        color: #1e293b;
    }

    /* Typography */
    .text-gradient {
        background: linear-gradient(135deg, #fb923c 0%, #ea580c 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    h1, h2, h3 {
        font-weight: 700;
        letter-spacing: -0.025em;
    }

    /* Buttons */
    .btn-download {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        color: white !important;
        padding: 16px 32px;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 1.125rem;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 25px -5px rgba(234, 88, 12, 0.5);
        border: none;
        cursor: pointer;
    }

    .btn-download:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 20px 35px -5px rgba(234, 88, 12, 0.6);
    }

    /* Hero Section */
    .hero-section {
        background: radial-gradient(circle at top right, #0f172a 0%, #1e1b4b 100%);
        min-height: 90vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        color: white;
        padding: 80px 0;
    }

    .hero-bg-shapes {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: 1;
        overflow: hidden;
        pointer-events: none;
    }

    .shape-1 {
        position: absolute;
        width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(234,88,12,0.3) 0%, rgba(0,0,0,0) 70%);
        top: -100px; left: -200px;
        border-radius: 50%;
    }

    .shape-2 {
        position: absolute;
        width: 800px; height: 800px;
        background: radial-gradient(circle, rgba(139,92,246,0.3) 0%, rgba(0,0,0,0) 70%);
        bottom: -200px; right: -200px;
        border-radius: 50%;
    }

    .hero-content {
        z-index: 2;
        position: relative;
    }

    .hero-mockup-container {
        position: relative;
        z-index: 2;
        perspective: 1000px;
    }

    .hero-mockup {
        background: #000;
        border-radius: 40px;
        border: 12px solid #334155;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        transform: rotateY(-10deg) rotateX(5deg) translateY(0);
        transition: transform 0.5s ease;
        animation: floatPhone 6s ease-in-out infinite;
        max-width: 320px;
        margin: 0 auto;
    }

    @@keyframes floatPhone {
        0%, 100% { transform: rotateY(-10deg) rotateX(5deg) translateY(0); }
        50% { transform: rotateY(-10deg) rotateX(5deg) translateY(-20px); }
    }

    /* Features Section */
    .features-section {
        padding: 100px 0;
        background-color: #ffffff;
        position: relative;
    }

    .feature-row {
        align-items: center;
        margin-bottom: 120px;
    }

    .feature-row:last-child {
        margin-bottom: 0;
    }

    .feature-text-block {
        padding: 40px;
    }

    .feature-badge {
        display: inline-block;
        background: rgba(234, 88, 12, 0.1);
        color: #ea580c;
        padding: 8px 16px;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 0.875rem;
        margin-bottom: 16px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .app-screen-card {
        background: white;
        border-radius: 32px;
        padding: 12px;
        box-shadow: 0 20px 40px -5px rgba(0,0,0,0.1), 0 10px 20px -5px rgba(0,0,0,0.04);
        position: relative;
        max-width: 300px;
        margin: 0 auto;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .app-screen-card:hover {
        transform: translateY(-10px);
    }

    .app-screen-card img {
        border-radius: 20px;
        width: 100%;
        display: block;
    }

    /* CTA Section */
    .cta-section {
        padding: 120px 0;
        background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
        text-align: center;
        position: relative;
    }
    
    .cta-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 32px;
        padding: 60px 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        max-width: 800px;
        margin: 0 auto;
    }

    /* Animations */
    .fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        opacity: 0;
        transform: translateY(30px);
    }

    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }

    @@keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="app-landing-wrapper">
    
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-bg-shapes">
            <div class="shape-1"></div>
            <div class="shape-2"></div>
        </div>
        
        <div class="container hero-content">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-5 mb-lg-0 text-center text-lg-start fade-in-up">
                    <span class="badge rounded-pill px-3 py-2 mb-4 d-inline-flex align-items-center gap-2" style="background-color: #ea580c;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-stars" viewBox="0 0 16 16"><path d="M7.657 6.247c.11-.33.576-.33.686 0l.645 1.937a2.89 2.89 0 0 0 1.829 1.828l1.936.645c.33.11.33.576 0 .686l-1.937.645a2.89 2.89 0 0 0-1.828 1.829l-.645 1.936a.361.361 0 0 1-.686 0l-.645-1.937a2.89 2.89 0 0 0-1.828-1.828l-1.937-.645a.361.361 0 0 1 0-.686l1.937-.645a2.89 2.89 0 0 0 1.828-1.828l.645-1.937zM3.794 1.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387A1.734 1.734 0 0 0 4.593 5.69l-.387 1.162a.217.217 0 0 1-.412 0L3.407 5.69A1.734 1.734 0 0 0 2.31 4.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387A1.734 1.734 0 0 0 3.407 2.31l.387-1.162zM10.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.156 1.156 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.156 1.156 0 0 0-.732-.732L9.1 2.137a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732L10.863.1z"/></svg>
                        Khám Phá Cùng App
                    </span>
                    <h1 class="display-3 mb-4 fw-bold">Du lịch thông minh <span class="text-gradient">tiện lợi</span></h1>
                    <p class="lead mb-5 text-light opacity-75">Ứng dụng mang đến giải pháp trải nghiệm hoàn hảo với đầy đủ các tính năng đặt tour, chọn địa điểm và thuyết minh giọng nói tự động.</p>
                    
                    <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-lg-start delay-200 fade-in-up">
                        <!-- LINK TẢI APP SAU KHI BUILD SẼ THÊM VÀO THUỘC TÍNH HREF Ở BOX DƯỚI ĐÂY -->
                        <a href="javascript:alert('Đường dẫn tải file APK sẽ được cập nhật sau khi build ứng dụng!');" class="btn-download">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            Tải App ngay (.APK)
                        </a>
                    </div>
                </div>
                <div class="col-lg-6 delay-300 fade-in-up">
                    <div class="hero-mockup-container">
                        <div class="hero-mockup">
                            <!-- Ảnh Demo Trải nghiệm chính / Splash screen -->
                            <img src="~/images/app-showcase/giao_dien_ban_dau.jpg" onerror="this.src='https://placehold.co/800x1600/3b82f6/white?text=A%cc%89nh+Mo%cc%9b%cc%89+%C4%90a%cc%82%cc%80u'" alt="App Splash Screen" class="img-fluid w-100 h-100 object-fit-cover" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- App Features Overview -->
    <section class="features-section">
        <div class="container">
            <div class="text-center mb-5 pb-4 fade-in-up">
                <h2 class="display-5 fw-bold mb-3">Tính năng nổi bật của ứng dụng</h2>
                <p class="lead text-muted max-w-2xl mx-auto">Sẵn sàng để tận hưởng chuyến phiêu lưu không giới hạn với những công nghệ hỗ trợ du lịch vượt trội.</p>
            </div>

            <!-- Feature 1: Trang chủ hiện tour -->
            <div class="row feature-row fade-in-up">
                <div class="col-md-6 order-2 order-md-1">
                    <div class="app-screen-card">
                        <img src="~/images/app-showcase/giao_dien_trang_chu_hien_tour.jpg" onerror="this.src='https://placehold.co/800x1600/f1f5f9/94a3b8?text=Trang+Chu%cc%89'" alt="Giao diện Trang chủ hiện tour" />
                    </div>
                </div>
                <div class="col-md-6 order-1 order-md-2 feature-text-block">
                    <span class="feature-badge">01. Khám Phá Tour</span>
                    <h3 class="h1 mb-4">Giao diện danh sách Tour hấp dẫn</h3>
                    <p class="text-muted fs-5 mb-4">Màn hình trang chủ cung cấp loạt các Tour và địa danh khám phá được tổ chức một cách trực quan, giúp bạn dễ dàng tìm kiếm lịch trình phù hợp để lên kế hoạch trải nghiệm ngay lập tức.</p>
                </div>
            </div>

            <!-- Feature 2: Chi tiết địa điểm (Point) -->
            <div class="row feature-row fade-in-up">
                <div class="col-md-6 feature-text-block">
                    <span class="feature-badge">02. Thông Tin Chi Tiết Điểm Đến</span>
                    <h3 class="h1 mb-4">Mọi thông tin bạn cần về địa điểm</h3>
                    <p class="text-muted fs-5 mb-4">Bạn muốn biết địa danh đó có gì hay? Màn hình chi tiết điểm tham quan (Point) sẽ hiển thị đầy đủ hình ảnh, mô tả phong phú. Giúp bạn luôn tự do tự tại như một người bản địa.</p>
                </div>
                <div class="col-md-6 text-center">
                    <div class="app-screen-card">
                        <img src="~/images/app-showcase/giao_dien_chi_tiet_point.jpg" onerror="this.src='https://placehold.co/800x1600/f8fafc/94a3b8?text=Chi+tie%cc%81t'" alt="Chi tiết điểm du lịch" />
                    </div>
                </div>
            </div>

            <!-- Feature 3: Popup thuyết minh -->
            <div class="row feature-row fade-in-up">
                <div class="col-md-6 order-2 order-md-1">
                    <div class="app-screen-card">
                        <img src="~/images/app-showcase/giao_dien_popup_doc_thuyet_minh_tu_dong.jpg" onerror="this.src='https://placehold.co/800x1600/f1f5f9/94a3b8?text=Thuye%cc%81t+minh'" alt="Thuyết minh tự động" />
                    </div>
                </div>
                <div class="col-md-6 order-1 order-md-2 feature-text-block">
                    <span class="feature-badge">03. Trợ Lý Thuyết Minh Tự Động</span>
                    <h3 class="h1 mb-4">Lắng nghe câu chuyện âm thanh</h3>
                    <p class="text-muted fs-5 mb-4">Mang tính đột phá lớn nhất: Giao diện sẽ tự động xuất hiện popup chạy audio đọc thuyết minh khi hệ thống nhận diện bạn đang bước vào bán kính của một khu vực tham quan! Nhẹ nhàng lắng nghe các câu chuyện lịch sử tự động.</p>
                </div>
            </div>

            <!-- Feature 4: Cài đặt và Đổi ngôn ngữ -->
            <div class="row feature-row fade-in-up">
                <div class="col-md-6 feature-text-block">
                    <span class="feature-badge">04. Cài Đặt Cá Nhân Tùy Chỉnh</span>
                    <h3 class="h1 mb-4">Linh hoạt Thay đổi Ngôn Ngữ</h3>
                    <p class="text-muted fs-5 mb-4">Với mục tiêu giúp khách nước ngoài dễ dàng tiếp cận, ứng dụng được trang bị mục Cài đặt trực quan hỗ trợ đổi từ tiếng Việt sang các thứ tiếng thông dụng, đảm bảo hành trình toàn cầu trọn vẹn.</p>
                </div>
                <div class="col-md-6 text-center">
                    <div class="d-flex justify-content-center gap-4 align-items-center">
                        <div class="app-screen-card" style="transform: rotate(-3deg); margin-right: -40px; z-index: 2;">
                            <img src="~/images/app-showcase/giao_dien_cai_dat.jpg" onerror="this.src='https://placehold.co/800x1600/f8fafc/94a3b8?text=Ca%cc%80i+%C4%91a%cc%A3%cc%86t'" alt="Cài đặt" />
                        </div>
                        <div class="app-screen-card" style="transform: rotate(3deg); margin-top: 40px; z-index: 5;">
                            <img src="~/images/app-showcase/giao_dien_doi_ngon_ngu.jpg" onerror="this.src='https://placehold.co/800x1600/f8fafc/94a3b8?text=Ngo%cc%82n+Ngu%cc%9b%cc%83'" alt="Đổi ngôn ngữ" />
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- Bottom CTA -->
    <section class="cta-section">
        <div class="container">
            <div class="cta-card fade-in-up">
                <h2 class="display-5 fw-bold mb-4">Sẵn sàng để thử nghiệm?</h2>
                <p class="lead text-muted mb-5">Đừng bỏ lỡ trải nghiệm tuyệt vời. Ứng dụng đã sẵn sàng được cài đặt trên thiết bị của bạn.</p>
                <!-- LINK TẢI Ở ĐÂY NỮA -->
                <a href="javascript:alert('Đường dẫn tải file APK sẽ được cập nhật sau!');" class="btn-download px-5 py-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    <span class="fs-4">Tải .APK Ngay</span>
                </a>
                <p class="text-muted mt-4 fs-6">Hỗ trợ các dòng điện thoại Android 8.0 trở lên.</p>
            </div>
        </div>
    </section>

</div>
